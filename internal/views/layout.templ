		<body class="bg-background text-foreground antialiased surface-desk" data-ui-settings={ uiSettingsJSON(uiSettings) }>
			<div class="flex h-screen overflow-hidden">
				@Sidebar(accounts, "", uiSettingGet(uiSettings, "sidebar_width", "256px"))
