			<script src="/assets/js/resize.js"></script>
			<script>
				function setupEditAccountDialog() {
					var dlg = document.querySelector('#edit-account-dialog dialog[data-tui-dialog-content]');
					if (!dlg) return;

					if (window.tui && window.tui.dialog) {
						window.tui.dialog.open('edit-account-dialog');
					}

					requestAnimationFrame(function() {
						var vp = document.getElementById('edit-wizard-viewport');
						var track = document.getElementById('edit-wizard-track');
						if (!vp || !track || !dlg.open) return;

						vp.style.transition = 'none';
						vp.style.height = '9999px';
						track.style.transform = 'translateX(0)';
						if (typeof _editWizStep !== 'undefined') _editWizStep = 0;
						void vp.offsetHeight;
						var p = track.children[0];
						if (p) vp.style.height = p.scrollHeight + 'px';
						void vp.offsetHeight;
						vp.style.transition = 'height .3s ease-in-out';

						document.querySelectorAll('#edit-account-dialog .wizard-dot').forEach(function(d) {
							d.classList.toggle('active', +d.dataset.step === 0);
						});
					});
				}

				document.addEventListener('htmx:afterSettle', function(e) {
					if (e.target && e.target.querySelector && e.target.querySelector('#edit-account-dialog')) {
						setTimeout(setupEditAccountDialog, 20);
					}
				});
			</script>
		</body>
	</html>
}

templ ResizeHandle(panel string) {
	<div
		class="resize-handle"
		data-panel={ panel }
		draggable="false"
	></div>
}

templ SavedPanelSizeStyle() {
	<script>
		(function() {
			var settings = {};
			try {
				settings = JSON.parse(localStorage.getItem("gofer:ui_settings") || "{}") || {};
			} catch (_) {}

			function px(value, min, max) {
				var n = parseInt(value, 10);
				if (isNaN(n) || n <= 0) return null;
				return Math.max(min, Math.min(max, n));
			}

			var vw = window.innerWidth || 1024;
			var sidebar = px(settings.sidebar_width, 180, Math.min(400, vw * 0.25));
			var mailList = px(settings.mail_list_width, 300, Math.min(1200, vw * 0.55));
			if (!sidebar && !mailList) return;

			var style = document.createElement("style");
			style.setAttribute("data-saved-panel-size-style", "");
			style.textContent = (sidebar ? "aside{width:" + sidebar + "px!important}" : "") + (mailList ? "#mail-list{width:" + mailList + "px!important}" : "");
			document.head.appendChild(style);
		})();
	</script>
}

templ SidebarAccountCollapseStyle() {
	<script>
		(function() {
			var state = {};
			try {
				state = JSON.parse(localStorage.getItem("gofer:sidebar_account_collapsed") || "{}") || {};
			} catch (_) {}
			var escapeIdent = window.CSS && CSS.escape ? CSS.escape : function(value) { return String(value).replace(/[^a-zA-Z0-9_-]/g, "\\\\$&"); };
			var rules = [];
			Object.keys(state).forEach(function(accountId) {
				if (state[accountId] !== true) return;
				var selector = '[data-sidebar-account="' + escapeIdent(accountId) + '"]:not([data-sidebar-account-active])';
				rules.push(selector + ' .sidebar-account-folders{grid-template-rows:0fr;opacity:0;margin-top:-0.125rem;transition:none}');
				rules.push(selector + ' .sidebar-account-chevron{transform:rotate(-90deg);transition:none}');
			});
			if (!rules.length) return;
			var style = document.createElement("style");
			style.setAttribute("data-sidebar-account-collapse-style", "");
			style.textContent = rules.join("\n");
			document.head.appendChild(style);
		})();
	</script>
}

templ FolderPartial(accounts []models.Account, emails []models.Email, activeFolder string, selectedEmail *models.Email, totalCount int, selectedThread []models.ThreadItem, uiSettings map[string]string) {
	@MailList(accounts, emails, activeFolder, selectedEmail, totalCount, uiSettingGet(uiSettings, "mail_list_width", "384px"), uiSettingGet(uiSettings, "sender_display", "name"), uiSettingGet(uiSettings, "mail_list_view", "cards"))
	<div id="mail-view" class="hidden lg:flex flex-1 flex-col min-w-0 bg-background surface-desk" hx-swap-oob="true">
		if selectedEmail != nil {
			@MailViewContent(selectedEmail, selectedThread)
		} else {
			@MailViewEmpty()
		}
	</div>
}

templ MailContentPartial(accounts []models.Account, emails []models.Email, activeFolder string, selectedEmail *models.Email, totalCount int, selectedThread []models.ThreadItem, uiSettings map[string]string) {
	<div id="main-content" class="flex flex-1 min-w-0">
		@MailList(accounts, emails, activeFolder, selectedEmail, totalCount, uiSettingGet(uiSettings, "mail_list_width", "384px"), uiSettingGet(uiSettings, "sender_display", "name"), uiSettingGet(uiSettings, "mail_list_view", "cards"))
		@ResizeHandle("maillist")
		@MailView(selectedEmail, selectedThread)
	</div>
}

templ SettingsPartial(accounts []models.Account, syncSettings models.SyncSettings, activeTab string, uiSettings map[string]string) {
	<div id="main-content" class="flex flex-1 min-w-0">
		@SettingsPage(accounts, syncSettings, activeTab, uiSettings)
	</div>
	@ChooseAccountTypeDialog()
	@GmailAccountDialog()
	@AddAccountDialog()
	<div id="edit-account-container"></div>
}
