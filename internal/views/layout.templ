package views

import (
	"github.com/cristianadrielbraun/gofer/internal/models"

	"github.com/cristianadrielbraun/gofer/components/copybutton"
	"github.com/cristianadrielbraun/gofer/components/dialog"
	"github.com/cristianadrielbraun/gofer/components/dropdown"
	"github.com/cristianadrielbraun/gofer/components/checkbox"
	"github.com/cristianadrielbraun/gofer/components/calendar"
	"github.com/cristianadrielbraun/gofer/components/input"
	"github.com/cristianadrielbraun/gofer/components/popover"
	"github.com/cristianadrielbraun/gofer/components/selectbox"
	"github.com/cristianadrielbraun/gofer/components/tabs"
	"github.com/cristianadrielbraun/gofer/components/tooltip"
	"github.com/cristianadrielbraun/gofer/components/toast"
)

templ Layout(accounts []models.Account, activeFolder string, emails []models.Email, selectedEmail *models.Email, totalCount int, uiSettings map[string]string, selectedThread []models.ThreadItem, initialEmailID string) {
	<!DOCTYPE html>
	<html lang="en" class={ themeClass(uiSettings) } data-theme={ themeStyle(uiSettings) }>
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>Gofer</title>
			<link rel="preconnect" href="https://fonts.googleapis.com"/>
			<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
			<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400&family=Nunito+Sans:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet"/>
			@SavedPanelSizeStyle()
			<link rel="stylesheet" href="/assets/css/output.css"/>
			@dialog.Script()
			@dropdown.Script()
			@checkbox.Script()
			@calendar.Script()
			@input.Script()
			@selectbox.Script()
			@tabs.Script()
			@tooltip.Script()
			@popover.Script()
			@copybutton.Script()
			@toast.Script()
			@AppSidebarResponsiveStyle()
		</head>
		<body class="bg-background text-foreground antialiased surface-desk" data-ui-settings={ uiSettingsJSON(uiSettings) } data-initial-email-id={ initialEmailID }>
			<div id="app-shell" class="flex h-screen overflow-hidden">
				@Sidebar(accounts, activeFolder, uiSettingGet(uiSettings, "sidebar_width", "256px"), uiSettings)
				@ResizeHandle("sidebar")
				<div id="main-content" class="flex flex-1 min-w-0">
					@MailList(accounts, emails, activeFolder, selectedEmail, totalCount, 0, uiSettingGet(uiSettings, "mail_list_width", "384px"), uiSettingGet(uiSettings, "sender_display", "name"), uiSettingGet(uiSettings, "mail_list_view", "cards"))
					@ResizeHandle("maillist")
					if initialEmailID != "" && selectedEmail == nil {
						@MailViewLoading()
					} else {
						@MailView(selectedEmail, selectedThread)
					}
				</div>
			</div>
			@ComposeDialog(accounts)
			@ChooseAccountTypeDialog()
			@GmailAccountDialog()
			@AddAccountDialog()
			@MailSyncProgressDialog()
			<div id="edit-account-container"></div>
			<script src="/assets/js/htmx.min.js"></script>
			<script src="/assets/js/virtual-scroll.js"></script>
			<script src="/assets/js/app.js"></script>
			<script src="/assets/js/settings.js"></script>
			<script src="/assets/js/ui-settings.js"></script>
			<script src="/assets/js/resize.js"></script>
			<script>
				function setupEditAccountDialog() {
					var dlg = document.querySelector('#edit-account-dialog dialog[data-tui-dialog-content]');
					if (!dlg) return;

					if (window.tui && window.tui.dialog) {
						window.tui.dialog.open('edit-account-dialog');
					}

					requestAnimationFrame(function() {
						var track = document.getElementById('edit-wizard-track');
						if (!track || !dlg.open) return;

						track.style.transform = 'translateX(0)';
						if (typeof _editWizStep !== 'undefined') _editWizStep = 0;

						document.querySelectorAll('#edit-account-dialog [data-account-wizard-step]').forEach(function(item) {
							item.dataset.active = String(+item.dataset.accountWizardStep === 0);
							if (+item.dataset.accountWizardStep === 4) item.disabled = true;
						});
					});
				}

				document.addEventListener('htmx:afterSettle', function(e) {
					if (e.target && e.target.querySelector && e.target.querySelector('#edit-account-dialog')) {
						setTimeout(setupEditAccountDialog, 20);
					}
				});
			</script>
		</body>
	</html>
}

templ MailSyncProgressDialog() {
	@dialog.Dialog(dialog.Props{ID: "mail-sync-progress-dialog"}) {
		@dialog.Content(dialog.ContentProps{Class: "sm:max-w-2xl max-h-[calc(100vh-2rem)]"}) {
			@dialog.Header() {
				@dialog.Title() { Mail sync progress }
				@dialog.Description() {
					<span class="inline-flex items-center gap-2">
						<span data-mail-sync-dialog-subtitle>Waiting for sync details...</span>
						<button type="button" class="hidden text-xs font-medium text-muted-foreground underline underline-offset-2 hover:text-foreground disabled:pointer-events-none disabled:opacity-60" data-mail-sync-cancel>Cancel</button>
					</span>
				}
			}
			<div class="min-h-0 space-y-4">
				<div class="space-y-2">
					<div class="flex items-center justify-between gap-3 text-xs font-medium text-muted-foreground">
						<span data-mail-sync-dialog-summary>Preparing...</span>
						<span data-mail-sync-dialog-percent>0%</span>
					</div>
					<div class="h-2 overflow-hidden rounded-full bg-muted">
						<div class="h-full rounded-full bg-primary transition-all" data-mail-sync-dialog-bar style="width:0%"></div>
					</div>
				</div>
				<div class="min-h-0 space-y-2 overflow-y-auto" style="max-height:min(28rem,calc(100vh - 14rem))" data-mail-sync-dialog-accounts></div>
			</div>
		}
	}
}

templ SettingsLayout(accounts []models.Account, syncSettings models.SyncSettings, activeTab string, uiSettings map[string]string, signatureData []models.AccountSignatureData) {
	<!DOCTYPE html>
	<html lang="en" class={ themeClass(uiSettings) } data-theme={ themeStyle(uiSettings) }>
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>Settings — Gofer</title>
			<link rel="preconnect" href="https://fonts.googleapis.com"/>
			<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
			<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,400&family=Nunito+Sans:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet"/>
			@SavedPanelSizeStyle()
			<link rel="stylesheet" href="/assets/css/output.css"/>
			@dialog.Script()
			@dropdown.Script()
			@checkbox.Script()
			@calendar.Script()
			@input.Script()
			@selectbox.Script()
			@tabs.Script()
			@tooltip.Script()
			@popover.Script()
			@copybutton.Script()
			@toast.Script()
			@AppSidebarResponsiveStyle()
		</head>
		<body class="bg-background text-foreground antialiased surface-desk" data-ui-settings={ uiSettingsJSON(uiSettings) }>
			<div id="app-shell" class="flex h-screen overflow-hidden">
