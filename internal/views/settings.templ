package views

import (
	"fmt"
	"github.com/cristianadrielbraun/gofer/internal/models"
	"strconv"
	"strings"

	"github.com/cristianadrielbraun/gofer/components/button"
	"github.com/cristianadrielbraun/gofer/components/checkbox"
	"github.com/cristianadrielbraun/gofer/components/dialog"
	"github.com/cristianadrielbraun/gofer/components/dropdown"
	"github.com/cristianadrielbraun/gofer/components/icon"
	"github.com/cristianadrielbraun/gofer/components/input"
	"github.com/cristianadrielbraun/gofer/components/popover"
	"github.com/cristianadrielbraun/gofer/components/radio"
	"github.com/cristianadrielbraun/gofer/components/selectbox"
	"github.com/cristianadrielbraun/gofer/components/tooltip"
	switchcomp "github.com/cristianadrielbraun/gofer/components/switch"
)

templ SettingsPage(accounts []models.Account, syncSettings models.SyncSettings, activeTab string, uiSettings map[string]string, signatureData []models.AccountSignatureData) {
	<div class="flex-1 flex flex-col min-w-0 overflow-hidden" data-settings-page>
		<div class="flex-1 overflow-y-auto">
			<div id="settings-content" class="max-w-3xl px-8 py-10">
				<div class="mb-6">
					<h2 class="text-2xl font-bold text-foreground mb-1" style="font-family: var(--font-serif)">Settings</h2>
					<p class="text-sm text-muted-foreground">Manage your accounts and preferences</p>
				</div>
				if activeTab == "accounts" {
					@SettingsAccountsTab(accounts)
				} else if activeTab == "sync" {
					@SettingsSyncTab(syncSettings)
				} else if activeTab == "contacts" {
					@SettingsContactsTab(accounts, uiSettings)
				} else if activeTab == "appearance" {
					@SettingsAppearanceTab(uiSettings)
				} else if activeTab == "compose-display" {
					@SettingsComposeDisplayTab(uiSettings, signatureData)
				} else if activeTab == "advanced" {
					@SettingsAdvancedTab(uiSettings)
				}
			</div>
		</div>
	</div>
}

templ SettingsComposeDisplayTab(uiSettings map[string]string, signatureData []models.AccountSignatureData) {
	<div class="mt-6 space-y-6">
		<div class="bg-card rounded-lg border p-6 space-y-5">
			<div>
				<h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-1">New emails</h3>
				<p class="text-xs text-muted-foreground">Choose how a new compose window opens when you start an email.</p>
			</div>
			<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div class="min-w-0">
					<h4 class="text-sm font-medium text-foreground">Default compose view</h4>
					<p class="text-xs text-muted-foreground mt-1">Pick whether new messages start in a dialog, the reading pane, or the full-width composer.</p>
				</div>
				<div class="w-full sm:w-44 shrink-0" data-compose-view-picker>
					@selectbox.SelectBox(selectbox.Props{Class: "settings-select"}) {
						@selectbox.Trigger(selectbox.TriggerProps{Name: "default_compose_view", Class: "bg-background", DisableClear: true}) {
							@selectbox.Value(selectbox.ValueProps{Placeholder: "Dialog"}) {
								{ defaultComposeViewSettingLabel(uiSettingGet(uiSettings, "default_compose_view", "dialog")) }
							}
						}
						@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
							@selectbox.Item(selectbox.ItemProps{Value: "dialog", Selected: uiSettingGet(uiSettings, "default_compose_view", "dialog") == "dialog"}) { Dialog }
							@selectbox.Item(selectbox.ItemProps{Value: "pane", Selected: uiSettingGet(uiSettings, "default_compose_view", "dialog") == "pane"}) { Right pane }
							@selectbox.Item(selectbox.ItemProps{Value: "full", Selected: uiSettingGet(uiSettings, "default_compose_view", "dialog") == "full"}) { Full width }
						}
					}
				</div>
			</div>
			<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
				<div class="min-w-0">
					<label for="compose-autosave-enabled" class="text-sm font-medium text-foreground">Autosave drafts</label>
					<p class="text-xs text-muted-foreground mt-1">Save drafts after meaningful compose activity instead of creating drafts for tiny edits.</p>
				</div>
				<div class="w-full sm:w-44 shrink-0 space-y-3" data-compose-autosave-controls>
					<div class="flex items-center justify-between gap-3 rounded-md border border-border/60 bg-background/40 px-3 py-2">
						<span class="text-xs font-medium text-muted-foreground">Enable autosave</span>
						@switchcomp.Switch(switchcomp.Props{
							ID:      "compose-autosave-enabled",
							Name:    "compose_autosave_enabled",
							Checked: uiSettingGet(uiSettings, "compose_autosave_enabled", "true") != "false",
							Attributes: templ.Attributes{"data-compose-autosave-setting": "enabled"},
						})
					</div>
					<div data-compose-autosave-dependent>
						<input type="hidden" name="compose_autosave_conditions" value={ uiSettingGet(uiSettings, "compose_autosave_conditions", "chars,attachment") } data-compose-autosave-conditions-value/>
						@dropdown.Dropdown() {
							@dropdown.Trigger() {
								@button.Button(button.Props{Variant: button.VariantOutline, Class: "settings-select select-trigger w-full h-9 justify-between bg-background", Disabled: uiSettingGet(uiSettings, "compose_autosave_enabled", "true") == "false", Attributes: templ.Attributes{"data-compose-autosave-conditions-button": ""}}) {
									<span data-compose-autosave-conditions-label>{ composeAutosaveConditionsLabel(uiSettings) }</span>
									@icon.ChevronDown(icon.Props{Class: "size-4 text-muted-foreground"})
								}
							}
							@dropdown.Content(dropdown.ContentProps{Placement: dropdown.PlacementBottomEnd, Class: "w-64 normal-case tracking-normal", Attributes: templ.Attributes{"data-compose-autosave-conditions-menu": ""}}) {
								@dropdown.Label(dropdown.LabelProps{Class: "text-xs text-muted-foreground"}) { Autosave when }
								<div class="flex items-center gap-2 rounded-sm px-2 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground" data-compose-autosave-condition-item="chars">
									<span class={ "w-4 shrink-0 text-primary", templ.KV("opacity-0", !uiSettingCSVHas(uiSettings, "compose_autosave_conditions", "chars,attachment", "chars")) } data-compose-autosave-condition-check="chars">@icon.Check(icon.Props{Class: "size-4"})</span>
									<span class="flex-1 text-left">Min characters</span>
									<input type="text" inputmode="numeric" pattern="[0-9]*" value={ uiSettingGet(uiSettings, "compose_autosave_min_chars", "30") } class="h-7 w-14 rounded-md border border-border bg-background px-2 text-xs text-foreground disabled:opacity-50" data-compose-autosave-min-chars disabled?={ uiSettingGet(uiSettings, "compose_autosave_enabled", "true") == "false" || !uiSettingCSVHas(uiSettings, "compose_autosave_conditions", "chars,attachment", "chars") }/>
								</div>
								@dropdown.Item(dropdown.ItemProps{PreventClose: true, Class: "gap-2", Attributes: templ.Attributes{"data-compose-autosave-condition-item": "attachment"}}) {
									<span class={ "w-4 shrink-0 text-primary", templ.KV("opacity-0", !uiSettingCSVHas(uiSettings, "compose_autosave_conditions", "chars,attachment", "attachment")) } data-compose-autosave-condition-check="attachment">@icon.Check(icon.Props{Class: "size-4"})</span>
									<span class="flex-1 text-left">Has attachment</span>
								}
								@dropdown.Item(dropdown.ItemProps{PreventClose: true, Class: "gap-2", Attributes: templ.Attributes{"data-compose-autosave-condition-item": "to"}}) {
									<span class={ "w-4 shrink-0 text-primary", templ.KV("opacity-0", !uiSettingCSVHas(uiSettings, "compose_autosave_conditions", "chars,attachment", "to")) } data-compose-autosave-condition-check="to">@icon.Check(icon.Props{Class: "size-4"})</span>
									<span class="flex-1 text-left">Has recipient</span>
								}
							}
						}
					</div>
					<div data-compose-autosave-dependent>
						@selectbox.SelectBox(selectbox.Props{Class: "settings-select"}) {
							@selectbox.Trigger(selectbox.TriggerProps{Name: "compose_autosave_debounce", Class: "bg-background", DisableClear: true, Disabled: uiSettingGet(uiSettings, "compose_autosave_enabled", "true") == "false"}) {
								@selectbox.Value(selectbox.ValueProps{Placeholder: "5 seconds"}) {
									{ composeAutosaveDebounceLabel(uiSettingGet(uiSettings, "compose_autosave_debounce", "5")) }
								}
							}
							@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
								@selectbox.Item(selectbox.ItemProps{Value: "1", Selected: uiSettingGet(uiSettings, "compose_autosave_debounce", "5") == "1"}) { 1 second }
								@selectbox.Item(selectbox.ItemProps{Value: "3", Selected: uiSettingGet(uiSettings, "compose_autosave_debounce", "5") == "3"}) { 3 seconds }
								@selectbox.Item(selectbox.ItemProps{Value: "5", Selected: uiSettingGet(uiSettings, "compose_autosave_debounce", "5") == "5"}) { 5 seconds }
								@selectbox.Item(selectbox.ItemProps{Value: "10", Selected: uiSettingGet(uiSettings, "compose_autosave_debounce", "5") == "10"}) { 10 seconds }
								@selectbox.Item(selectbox.ItemProps{Value: "15", Selected: uiSettingGet(uiSettings, "compose_autosave_debounce", "5") == "15"}) { 15 seconds }
							}
						}
					</div>
				</div>
			</div>
		</div>
		@AccountSignaturesSettings(signatureData)
		<div class="bg-card rounded-lg border p-6 space-y-5">
			<div>
				<h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-1">List view</h3>
				<p class="text-xs text-muted-foreground">Control how messages are summarized in the email list.</p>
			</div>
			<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div class="min-w-0">
					<h4 class="text-sm font-medium text-foreground">Sender display</h4>
					<p class="text-xs text-muted-foreground mt-1">Choose what appears in the From row. Messages without a sender name will still fall back to the email address.</p>
				</div>
				<div class="w-full sm:w-44 shrink-0" data-sender-display-picker>
					@selectbox.SelectBox(selectbox.Props{Class: "settings-select"}) {
						@selectbox.Trigger(selectbox.TriggerProps{Name: "sender_display", Class: "bg-background", DisableClear: true}) {
							@selectbox.Value(selectbox.ValueProps{Placeholder: "Only name"}) {
								{ senderDisplaySettingLabel(uiSettingGet(uiSettings, "sender_display", "name")) }
							}
						}
						@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
							@selectbox.Item(selectbox.ItemProps{Value: "name", Selected: uiSettingGet(uiSettings, "sender_display", "name") == "name"}) { Only name }
							@selectbox.Item(selectbox.ItemProps{Value: "email", Selected: uiSettingGet(uiSettings, "sender_display", "name") == "email"}) { Only email }
							@selectbox.Item(selectbox.ItemProps{Value: "both", Selected: uiSettingGet(uiSettings, "sender_display", "name") == "both"}) { Name and email }
						}
					}
				</div>
			</div>
			<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div class="min-w-0">
					<h4 class="text-sm font-medium text-foreground">Automatically mark email read after</h4>
					<p class="text-xs text-muted-foreground mt-1">Choose how long a message must stay open before it is marked as read.</p>
				</div>
				<div class="w-full sm:w-44 shrink-0" data-auto-mark-read-picker>
					@selectbox.SelectBox(selectbox.Props{Class: "settings-select"}) {
						@selectbox.Trigger(selectbox.TriggerProps{Name: "auto_mark_read_after", Class: "bg-background", DisableClear: true}) {
							@selectbox.Value(selectbox.ValueProps{Placeholder: "Immediately"}) {
								{ autoMarkReadSettingLabel(uiSettingGet(uiSettings, "auto_mark_read_after", "0")) }
							}
						}
						@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
							@selectbox.Item(selectbox.ItemProps{Value: "0", Selected: uiSettingGet(uiSettings, "auto_mark_read_after", "0") == "0"}) { Immediately }
							@selectbox.Item(selectbox.ItemProps{Value: "2", Selected: uiSettingGet(uiSettings, "auto_mark_read_after", "0") == "2"}) { After 2 seconds }
							@selectbox.Item(selectbox.ItemProps{Value: "5", Selected: uiSettingGet(uiSettings, "auto_mark_read_after", "0") == "5"}) { After 5 seconds }
							@selectbox.Item(selectbox.ItemProps{Value: "10", Selected: uiSettingGet(uiSettings, "auto_mark_read_after", "0") == "10"}) { After 10 seconds }
							@selectbox.Item(selectbox.ItemProps{Value: "never", Selected: uiSettingGet(uiSettings, "auto_mark_read_after", "0") == "never"}) { Never }
						}
					}
				</div>
			</div>
		</div>
	</div>
	<script>
	(function() {
		function composeAutosaveEnabled() {
			var toggle = document.querySelector('[data-compose-autosave-setting="enabled"]');
			return !toggle || toggle.checked;
		}
		function selectedComposeAutosaveConditions() {
			var input = document.querySelector('[data-compose-autosave-conditions-value]');
			return (input && input.value ? input.value : '').split(',').filter(Boolean);
		}
		function saveComposeAutosaveConditions(values) {
			var input = document.querySelector('[data-compose-autosave-conditions-value]');
			if (input) input.value = values.join(',');
			if (typeof GoferSettings !== 'undefined') GoferSettings.set('compose_autosave_conditions', values.join(','));
		}
		function composeAutosaveConditionLabel(values) {
			if (!values.length) return 'No conditions';
			return values.length === 1 ? '1 condition' : values.length + ' conditions';
		}
		function syncComposeAutosaveControls() {
			var enabled = composeAutosaveEnabled();
			var selected = selectedComposeAutosaveConditions();
			document.querySelectorAll('[data-compose-autosave-dependent] .select-trigger, [data-compose-autosave-conditions-button], [data-compose-autosave-min-chars]').forEach(function(el) {
				el.disabled = !enabled;
				el.classList.toggle('opacity-50', !enabled);
			});
			document.querySelectorAll('[data-compose-autosave-condition-check]').forEach(function(check) {
				check.classList.toggle('opacity-0', selected.indexOf(check.dataset.composeAutosaveConditionCheck) === -1);
			});
			var label = document.querySelector('[data-compose-autosave-conditions-label]');
			if (label) label.textContent = composeAutosaveConditionLabel(selected);
			var minChars = document.querySelector('[data-compose-autosave-min-chars]');
			if (minChars) minChars.disabled = !enabled || selected.indexOf('chars') === -1;
		}
		document.addEventListener('click', function(e) {
			var item = e.target.closest && e.target.closest('[data-compose-autosave-condition-item]');
			if (!item || e.target.closest('[data-compose-autosave-min-chars]')) return;
			var selected = selectedComposeAutosaveConditions();
			var value = item.dataset.composeAutosaveConditionItem;
			var index = selected.indexOf(value);
			if (index === -1) selected.push(value);
			else selected.splice(index, 1);
			saveComposeAutosaveConditions(selected);
			syncComposeAutosaveControls();
		});
		document.addEventListener('change', function(e) {
			var defaultComposeView = e.target.closest('input[name="default_compose_view"]');
			if (defaultComposeView && typeof GoferSettings !== 'undefined') {
				GoferSettings.set('default_compose_view', defaultComposeView.value);
			}
			var autosaveToggle = e.target.closest('[data-compose-autosave-setting="enabled"]');
			if (autosaveToggle && typeof GoferSettings !== 'undefined') {
				GoferSettings.set('compose_autosave_enabled', autosaveToggle.checked ? 'true' : 'false');
				syncComposeAutosaveControls();
			}
			var minChars = e.target.closest('[data-compose-autosave-min-chars]');
			if (minChars && typeof GoferSettings !== 'undefined') {
				var n = Math.max(1, Math.min(1000, parseInt(minChars.value.replace(/\D/g, '') || '30', 10) || 30));
				minChars.value = n;
				GoferSettings.set('compose_autosave_min_chars', String(n));
			}
			var autosaveDebounce = e.target.closest('input[name="compose_autosave_debounce"]');
			if (autosaveDebounce && typeof GoferSettings !== 'undefined') {
				GoferSettings.set('compose_autosave_debounce', autosaveDebounce.value);
			}
			var senderDisplay = e.target.closest('input[name="sender_display"]');
			if (senderDisplay && typeof GoferSettings !== 'undefined') {
				GoferSettings.set('sender_display', senderDisplay.value);
			}
			var autoMarkRead = e.target.closest('input[name="auto_mark_read_after"]');
			if (autoMarkRead && typeof GoferSettings !== 'undefined') {
				GoferSettings.set('auto_mark_read_after', autoMarkRead.value);
			}
		});
		document.addEventListener('input', function(e) {
			var minChars = e.target.closest && e.target.closest('[data-compose-autosave-min-chars]');
			if (!minChars) return;
			minChars.value = minChars.value.replace(/\D/g, '').slice(0, 4);
		});
		setTimeout(syncComposeAutosaveControls, 0);
	})();
	</script>
}

templ SettingsAppearanceTab(uiSettings map[string]string) {
		<div class="mt-6 space-y-6">
			<div class="bg-card rounded-lg border p-6 space-y-6">
				<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
					<div>
						<h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-1">Visual Style</h3>
						<p class="text-xs text-muted-foreground">Choose the overall look and feel of Gofer.</p>
					</div>
					<div class="space-y-1 sm:text-right" data-mode-picker>
						<h4 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider">Color Mode</h4>
						<div class="inline-flex rounded-lg border border-border bg-background p-0.5 gap-0.5">
							<button
								type="button"
								data-mode="light"
								class={
									"inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-medium transition-all duration-200",
									templ.KV("bg-background text-foreground shadow-sm", uiSettingGet(uiSettings, "theme", "dark") == "light"),
									templ.KV("text-muted-foreground hover:text-foreground", uiSettingGet(uiSettings, "theme", "dark") != "light"),
								}
							>
								<svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
								Light
							</button>
							<button
								type="button"
								data-mode="dark"
								class={
									"inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-medium transition-all duration-200",
									templ.KV("bg-background text-foreground shadow-sm", uiSettingGet(uiSettings, "theme", "dark") == "dark"),
									templ.KV("text-muted-foreground hover:text-foreground", uiSettingGet(uiSettings, "theme", "dark") != "dark"),
								}
							>
								<svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401"/></svg>
								Dark
							</button>
						</div>
					</div>
				</div>
				<div class="grid grid-cols-2 gap-4 max-w-lg" data-theme-picker>
					<label class="relative flex flex-col rounded-lg border-2 p-3 cursor-pointer transition-all duration-200 text-left hover:shadow-md group border-border has-[:checked]:border-primary has-[:checked]:ring-2 has-[:checked]:ring-primary/20">
						@radio.Radio(radio.Props{Name: "theme_style", Value: "classic", Checked: uiSettingGet(uiSettings, "theme_style", "classic") == "classic", Class: "absolute right-2.5 bottom-2.5 z-10"})
						<div data-theme="classic" data-theme-preview class={ "overflow-hidden h-36 mb-2 flex", templ.KV("dark", uiSettingGet(uiSettings, "theme", "dark") == "dark") } style="background:var(--background); border-radius:12px">
							<div class="w-1/4 p-2 flex flex-col gap-1.5" style="background:var(--sidebar)">
								<div style="height:3px; width:70%; background:var(--sidebar-foreground); opacity:0.5; border-radius:10px"></div>
								<div style="height:3px; width:90%; background:var(--sidebar-foreground); opacity:0.3; border-radius:10px"></div>
								<div style="height:3px; width:50%; background:var(--primary); opacity:0.7; border-radius:10px"></div>
								<div style="height:3px; width:80%; background:var(--sidebar-foreground); opacity:0.3; border-radius:10px"></div>
								<div style="height:3px; width:60%; background:var(--sidebar-foreground); opacity:0.3; border-radius:10px"></div>
							</div>
							<div class="flex-1 p-2 flex flex-col gap-1.5" style="background:var(--background)">
								<div style="height:3px; width:60%; background:var(--foreground); opacity:0.3; border-radius:10px; margin-bottom:2px"></div>
								<div class="flex-1 p-2 flex flex-col" style="background:var(--card); border:1px solid var(--border); border-radius:12px">
									<div style="height:2px; width:75%; background:var(--foreground); opacity:0.4; border-radius:10px; margin-bottom:3px"></div>
									<div style="height:2px; width:50%; background:var(--muted-foreground); opacity:0.3; border-radius:10px; margin-bottom:3px"></div>
									<div style="height:2px; width:85%; background:var(--foreground); opacity:0.2; border-radius:10px; margin-bottom:3px"></div>
									<div style="height:2px; width:60%; background:var(--foreground); opacity:0.15; border-radius:10px; margin-bottom:3px"></div>
									<div style="height:2px; width:90%; background:var(--foreground); opacity:0.1; border-radius:10px; margin-bottom:3px"></div>
									<div style="height:2px; width:40%; background:var(--foreground); opacity:0.15; border-radius:10px; margin-bottom:3px"></div>
									<div style="height:2px; width:70%; background:var(--foreground); opacity:0.1; border-radius:10px; margin-bottom:3px"></div>
									<div style="flex:1; width:100%; background:var(--secondary); border-radius:6px; margin-bottom:3px"></div>
									<div style="display:inline-flex; gap:4px; margin-top:auto">
										<div style="height:10px; width:28px; background:var(--primary); border-radius:8px"></div>
										<div style="height:10px; width:28px; background:var(--card); border:1px solid var(--border); border-radius:8px"></div>
									</div>
								</div>
							</div>
						</div>
						<span class="text-sm font-medium text-foreground leading-tight">Classic</span>
						<span class="text-xs text-muted-foreground">Warm tones, soft rounded</span>
					</label>

					<label class="relative flex flex-col rounded-lg border-2 p-3 cursor-pointer transition-all duration-200 text-left hover:shadow-md group border-border has-[:checked]:border-primary has-[:checked]:ring-2 has-[:checked]:ring-primary/20">
						@radio.Radio(radio.Props{Name: "theme_style", Value: "minimal", Checked: uiSettingGet(uiSettings, "theme_style", "classic") == "minimal", Class: "absolute right-2.5 bottom-2.5 z-10"})
						<div data-theme="minimal" data-theme-preview class={ "overflow-hidden h-36 mb-2 flex", templ.KV("dark", uiSettingGet(uiSettings, "theme", "dark") == "dark") } style="background:var(--background); border-radius:0">
							<div class="w-1/4 p-2 flex flex-col gap-1.5" style="background:var(--sidebar); border-right:1px solid var(--sidebar-border)">
								<div style="height:3px; width:70%; background:var(--sidebar-foreground); opacity:0.4; border-radius:0"></div>
								<div style="height:3px; width:90%; background:var(--sidebar-foreground); opacity:0.25; border-radius:0"></div>
								<div style="height:3px; width:50%; background:var(--primary); opacity:0.7; border-radius:0"></div>
								<div style="height:3px; width:80%; background:var(--sidebar-foreground); opacity:0.25; border-radius:0"></div>
								<div style="height:3px; width:60%; background:var(--sidebar-foreground); opacity:0.25; border-radius:0"></div>
							</div>
							<div class="flex-1 p-2 flex flex-col gap-1.5" style="background:var(--background)">
								<div style="height:3px; width:60%; background:var(--foreground); opacity:0.2; border-radius:0; margin-bottom:2px"></div>
								<div class="flex-1 p-2 flex flex-col" style="background:var(--card); border:1px solid var(--border); border-radius:0">
									<div style="height:2px; width:75%; background:var(--foreground); opacity:0.3; border-radius:0; margin-bottom:3px"></div>
									<div style="height:2px; width:50%; background:var(--muted-foreground); opacity:0.2; border-radius:0; margin-bottom:3px"></div>
									<div style="height:2px; width:85%; background:var(--foreground); opacity:0.12; border-radius:0; margin-bottom:3px"></div>
									<div style="height:2px; width:60%; background:var(--foreground); opacity:0.08; border-radius:0; margin-bottom:3px"></div>
									<div style="height:2px; width:90%; background:var(--foreground); opacity:0.05; border-radius:0; margin-bottom:3px"></div>
									<div style="height:2px; width:40%; background:var(--foreground); opacity:0.08; border-radius:0; margin-bottom:3px"></div>
									<div style="height:2px; width:70%; background:var(--foreground); opacity:0.05; border-radius:0; margin-bottom:3px"></div>
									<div style="flex:1; width:100%; background:var(--secondary); border-radius:0; margin-bottom:3px"></div>
									<div style="display:inline-flex; gap:4px; margin-top:auto">
										<div style="height:10px; width:28px; background:var(--primary); border-radius:0"></div>
										<div style="height:10px; width:28px; background:var(--card); border:1px solid var(--border); border-radius:0"></div>
									</div>
								</div>
							</div>
						</div>
						<span class="text-sm font-medium text-foreground leading-tight">Minimal</span>
						<span class="text-xs text-muted-foreground">Clean, flat, sharp edges</span>
					</label>
				</div>
			</div>
		</div>
	<script>
	(function() {
		document.addEventListener('click', function(e) {
			var mode = e.target.closest('[data-mode]');
			if (mode) {
				if (typeof GoferSettings !== 'undefined') {
					GoferSettings.set('theme', mode.dataset.mode);
				}
				var isDark = mode.dataset.mode === 'dark';
				document.querySelectorAll('[data-theme-preview]').forEach(function(el) {
					el.classList.toggle('dark', isDark);
				});
				return;
			}
		});
		document.addEventListener('change', function(e) {
			var themeStyle = e.target.closest('input[name="theme_style"]');
			if (themeStyle && typeof GoferSettings !== 'undefined') {
				GoferSettings.set('theme_style', themeStyle.value);
			}
		});
	})();
	</script>
}

templ SettingsAdvancedTab(uiSettings map[string]string) {
	<div class="mt-6 space-y-6">
		<div class="bg-card rounded-lg border p-6 space-y-5">
			<div>
				<h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-1">Advanced</h3>
				<p class="text-xs text-muted-foreground">Tune behavior that affects performance and network usage.</p>
			</div>
			<div class="flex items-start justify-between gap-6 rounded-lg border border-border/60 bg-background/40 p-4">
				<div class="min-w-0">
					<label for="prefetch-on-hover" class="text-sm font-medium text-foreground">Pre-fetch on hover</label>
					<p class="text-xs text-muted-foreground mt-1 leading-relaxed">Start loading an email body when you hover or focus a message in the list, so opening it often feels faster. This can significantly increase network usage. Disable it to fetch bodies only when you click an email.</p>
				</div>
				@switchcomp.Switch(switchcomp.Props{
					ID:      "prefetch-on-hover",
					Name:    "prefetch_on_hover",
					Checked: uiSettingGet(uiSettings, "prefetch_on_hover", "true") != "false",
					Attributes: templ.Attributes{"data-ui-setting-switch": "prefetch_on_hover"},
				})
			</div>
		</div>
	</div>
	<script>
	(function() {
		document.addEventListener('change', function(e) {
			var toggle = e.target.closest('[data-ui-setting-switch]');
			if (!toggle || typeof GoferSettings === 'undefined') return;
			GoferSettings.set(toggle.getAttribute('data-ui-setting-switch'), toggle.checked ? 'true' : 'false');
		});
	})();
	</script>
}

templ SettingsContactsTab(accounts []models.Account, uiSettings map[string]string) {
	<div class="mt-6 space-y-6">
		<div class="bg-card rounded-lg border p-6 space-y-5">
			<div>
				<h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-1">Local contacts</h3>
				<p class="text-xs text-muted-foreground">Control how Gofer builds and maintains your local address book from mail you already have.</p>
			</div>
			<div class="rounded-lg border border-border/60 bg-background/40 p-4 space-y-5">
				<div class="flex items-start justify-between gap-6">
					<div class="min-w-0">
						<label for="contacts-auto-create-observed" class="text-sm font-medium text-foreground">Auto-create observed contacts</label>
						<p class="text-xs text-muted-foreground mt-1 leading-relaxed">Create local contacts from selected discovery sources. Disable this if you only want manually saved contacts.</p>
					</div>
					@switchcomp.Switch(switchcomp.Props{
						ID:      "contacts-auto-create-observed",
						Name:    "contacts_auto_create_observed",
						Checked: uiSettingGet(uiSettings, "contacts_auto_create_observed", "true") != "false",
						Attributes: templ.Attributes{"data-ui-setting-switch": "contacts_auto_create_observed", "data-contact-autocreate-switch": ""},
					})
				</div>
				<fieldset
					data-contact-autocreate-dependent
					disabled?={ uiSettingGet(uiSettings, "contacts_auto_create_observed", "true") == "false" }
					class={
						"space-y-5 border-t border-border/60 pt-5 transition-opacity",
						templ.KV("opacity-45 pointer-events-none saturate-50", uiSettingGet(uiSettings, "contacts_auto_create_observed", "true") == "false"),
					}
				>
					<div class="space-y-4">
						<div class="min-w-0">
							<h4 class="text-sm font-medium text-foreground">Discovery sources</h4>
							<p class="text-xs text-muted-foreground mt-1 leading-relaxed">Choose which mail participants should be eligible for automatic contact creation.</p>
						</div>
						<div class="space-y-3">
							<div class="flex items-start justify-between gap-6">
								<div class="min-w-0">
									<label for="contacts-observed-senders" class="text-sm font-medium text-foreground">Senders</label>
									<p class="text-xs text-muted-foreground mt-1">Create contacts from message From addresses.</p>
								</div>
								@switchcomp.Switch(switchcomp.Props{
									ID:      "contacts-observed-senders",
									Name:    "contacts_observed_senders",
									Checked: uiSettingCSVHas(uiSettings, "contacts_observed_sources", "senders,recipients", "senders"),
									Attributes: templ.Attributes{"data-contact-source-switch": "senders"},
								})
							</div>
							<div class="flex items-start justify-between gap-6">
								<div class="min-w-0">
									<label for="contacts-observed-recipients" class="text-sm font-medium text-foreground">Recipients</label>
									<p class="text-xs text-muted-foreground mt-1">Create contacts from To, Cc, and Bcc addresses.</p>
								</div>
								@switchcomp.Switch(switchcomp.Props{
									ID:      "contacts-observed-recipients",
									Name:    "contacts_observed_recipients",
									Checked: uiSettingCSVHas(uiSettings, "contacts_observed_sources", "senders,recipients", "recipients"),
									Attributes: templ.Attributes{"data-contact-source-switch": "recipients"},
								})
							</div>
						</div>
					</div>
					<div class="flex items-start justify-between gap-6 border-t border-border/60 pt-5">
						<div class="min-w-0">
							<label for="contacts-prevent-recreate-deleted" class="text-sm font-medium text-foreground">Do not recreate deleted contacts</label>
							<p class="text-xs text-muted-foreground mt-1 leading-relaxed">When an observed contact is deleted, keep it suppressed so future mail from the same address does not add it back automatically.</p>
						</div>
						@switchcomp.Switch(switchcomp.Props{
							ID:      "contacts-prevent-recreate-deleted",
							Name:    "contacts_prevent_recreate_deleted",
							Checked: uiSettingGet(uiSettings, "contacts_prevent_recreate_deleted", "true") != "false",
							Attributes: templ.Attributes{"data-ui-setting-switch": "contacts_prevent_recreate_deleted"},
						})
					</div>
					<div class="flex items-start justify-between gap-6 border-t border-border/60 pt-5">
						<div class="min-w-0">
							<h4 class="text-sm font-medium text-foreground">Delete discovered contacts</h4>
							<p class="text-xs text-muted-foreground mt-1 leading-relaxed">Remove contacts that were created by discovery. Manually saved contacts are kept.</p>
						</div>
						@dialog.Trigger(dialog.TriggerProps{For: "delete-discovered-contacts-dialog"}) {
							<button type="button" class="inline-flex shrink-0 items-center gap-1.5 rounded-md border border-destructive/30 px-3 py-2 text-xs font-semibold text-destructive hover:bg-destructive/10">
								@icon.Trash2(icon.Props{Class: "size-3.5"})
								Delete discovered
							</button>
						}
					</div>
				</fieldset>
				@dialog.Dialog(dialog.Props{ID: "delete-discovered-contacts-dialog"}) {
					@dialog.Content(dialog.ContentProps{Class: "sm:max-w-md"}) {
						@dialog.Header() {
							@dialog.Title() { Delete discovered contacts }
							@dialog.Description() { Remove contacts Gofer created through discovery. Manually saved contacts will be kept. }
						}
						<div class="rounded-lg border border-destructive/15 bg-destructive/5 p-3 text-sm text-muted-foreground">
							This action deletes all discovered contacts. Deleted addresses may be suppressed from automatic recreation depending on your contact settings.
						</div>
						@dialog.Footer() {
							@dialog.Close() {
								<button type="button" class="inline-flex items-center justify-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg border border-border hover:bg-accent transition-colors">
									Cancel
								</button>
							}
							<form action="/api/settings/contacts/delete-observed" method="post">
								<button type="submit" class="inline-flex items-center justify-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-destructive text-white hover:bg-destructive/90 transition-colors">
									@icon.Trash2(icon.Props{Class: "size-4"})
									Delete discovered
								</button>
							</form>
						}
					}
				}
				<div id="contacts-suppressed-settings" hx-get="/api/settings/contacts/suppressed" hx-trigger="load" hx-swap="outerHTML" class="border-t border-border/60 pt-5">
					<div class="flex items-center justify-between gap-4">
						<div class="min-w-0">
							<div class="h-4 w-40 rounded bg-muted animate-pulse"></div>
							<div class="mt-2 h-3 w-64 rounded bg-muted animate-pulse"></div>
						</div>
						<div class="h-8 w-20 rounded bg-muted animate-pulse"></div>
					</div>
				</div>
			</div>
		</div>
		<div class="bg-card rounded-lg border p-6 space-y-3">
			<div>
				<h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-1">Provider sync</h3>
				<p class="text-xs text-muted-foreground">Sync contacts with connected accounts. Gmail uses your existing Google authorization; generic accounts will appear here when contact sync is configured.</p>
			</div>
			<div class="rounded-lg border border-border bg-background/40 p-4 space-y-3">
				<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
					<div class="min-w-0">
						<div class="flex flex-wrap items-center gap-2">
							<h4 class="text-sm font-medium text-foreground">Account contacts</h4>
							<span class="rounded-full bg-muted px-2 py-0.5 text-[11px] font-medium text-muted-foreground">{ fmt.Sprintf("%d accounts", len(contactSyncAccounts(accounts))) }</span>
						</div>
						<p class="text-xs text-muted-foreground mt-1 leading-relaxed">Pull provider changes and keep contacts linked to selected accounts up to date.</p>
					</div>
					if len(contactSyncAccounts(accounts)) > 0 {
						<form hx-post="/api/settings/contacts/accounts/sync" hx-target="#account-contact-sync-status" hx-swap="innerHTML">
							<button type="submit" class="inline-flex shrink-0 whitespace-nowrap items-center gap-1.5 rounded-md border border-border px-3 py-2 text-xs font-semibold text-foreground hover:bg-accent">
								@icon.RefreshCw(icon.Props{Class: "size-3.5"})
								Sync all accounts
							</button>
						</form>
					} else {
						<a href="/settings/accounts" hx-get="/settings/accounts" hx-select="#settings-content" hx-target="#settings-content" hx-swap="outerHTML" class="inline-flex shrink-0 items-center gap-1.5 rounded-md border border-border px-3 py-2 text-xs font-semibold text-foreground hover:bg-accent">
							@icon.Mail(icon.Props{Class: "size-3.5"})
							Connect account
						</a>
					}
				</div>
				if len(contactSyncAccounts(accounts)) > 0 {
					<div class="space-y-2 border-t border-border/60 pt-3">
						<p class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">Account sync</p>
						for _, account := range contactSyncAccounts(accounts) {
							<div class="flex items-center justify-between gap-3 rounded-md border border-border/70 bg-card/60 px-3 py-2">
								<div class="min-w-0">
									<p class="truncate text-xs font-medium text-foreground">{ account.Name }</p>
									<p class="truncate text-[11px] text-muted-foreground">{ contactProviderLabel(account) } - { account.Email }</p>
								</div>
								<form hx-post="/api/settings/contacts/accounts/sync" hx-target="#account-contact-sync-status" hx-swap="innerHTML">
									<input type="hidden" name="account_id" value={ account.ID }/>
									<button type="submit" class="inline-flex shrink-0 items-center gap-1.5 rounded-md border border-border px-2.5 py-1.5 text-xs font-semibold text-foreground hover:bg-accent">
										@icon.RefreshCw(icon.Props{Class: "size-3.5"})
										Sync
									</button>
								</form>
							</div>
						}
					</div>
				}
				<div id="account-contact-sync-status" class="mt-3"></div>
			</div>
		</div>
	</div>
	<script>
	(function() {
		function syncContactsAutoCreateDependents() {
			var master = document.querySelector('[data-contact-autocreate-switch]');
			var enabled = !master || master.checked;
			document.querySelectorAll('[data-contact-autocreate-dependent]').forEach(function(section) {
				section.disabled = !enabled;
				section.classList.toggle('opacity-45', !enabled);
				section.classList.toggle('pointer-events-none', !enabled);
				section.classList.toggle('saturate-50', !enabled);
			});
		}
		syncContactsAutoCreateDependents();
		document.addEventListener('change', function(e) {
			var toggle = e.target.closest('[data-ui-setting-switch]');
			if (toggle && typeof GoferSettings !== 'undefined') {
				GoferSettings.set(toggle.getAttribute('data-ui-setting-switch'), toggle.checked ? 'true' : 'false');
				if (toggle.hasAttribute('data-contact-autocreate-switch')) syncContactsAutoCreateDependents();
			}
			var source = e.target.closest('[data-contact-source-switch]');
			if (!source || typeof GoferSettings === 'undefined') return;
			var selected = [];
			document.querySelectorAll('[data-contact-source-switch]').forEach(function(el) {
				if (el.checked) selected.push(el.getAttribute('data-contact-source-switch'));
			});
			GoferSettings.set('contacts_observed_sources', selected.join(','));
		});
	})();
	</script>
}

templ GmailReauthForm(account models.Account) {
	<form method="POST" action="/api/accounts/oauth2/authorize">
		<input type="hidden" name="provider" value="gmail"/>
		<input type="hidden" name="email_address" value={ account.Email }/>
		<input type="hidden" name="display_name" value={ account.Name }/>
		<input type="hidden" name="imap_host" value="imap.gmail.com"/>
		<input type="hidden" name="imap_port" value="993"/>
		<input type="hidden" name="imap_tls_mode" value="tls"/>
		<input type="hidden" name="smtp_host" value="smtp.gmail.com"/>
		<input type="hidden" name="smtp_port" value="465"/>
		<input type="hidden" name="smtp_tls_mode" value="tls"/>
		<input type="hidden" name="auth_method" value="oauth2"/>
		<input type="hidden" name="username" value={ account.Email }/>
		<button type="submit" class="account-action-btn inline-flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground transition-colors px-2.5 py-1.5 rounded-md border border-border">
			@icon.RefreshCw(icon.Props{Class: "size-3.5"})
			Reconnect
		</button>
	</form>
}

func gmailAccounts(accounts []models.Account) []models.Account {
	out := make([]models.Account, 0, len(accounts))
	for _, account := range accounts {
		if account.Provider == "gmail" {
			out = append(out, account)
		}
	}
	return out
}

func contactSyncAccounts(accounts []models.Account) []models.Account {
	out := make([]models.Account, 0, len(accounts))
	for _, account := range accounts {
		if account.ContactSyncEnabled {
			out = append(out, account)
		}
	}
	return out
}

func contactProviderLabel(account models.Account) string {
switch account.ContactSyncProvider {
	case "gmail":
		return "Gmail"
	case "carddav":
		return "CardDAV"
	default:
		return "Contacts"
	}
}

templ SettingsSuppressedContacts(contacts []models.Contact, totalCount int) {
	<div id="contacts-suppressed-settings" class="border-t border-border/60 pt-5">
		<div class="flex items-start justify-between gap-6">
			<div class="min-w-0">
				<div class="flex items-center gap-2">
					<h4 class="text-sm font-medium text-foreground">Suppressed contacts</h4>
					<span class="rounded-full bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground">{ fmt.Sprintf("%d", totalCount) }</span>
				</div>
				<p class="text-xs text-muted-foreground mt-1 leading-relaxed">Deleted discovered contacts that should not be recreated automatically.</p>
			</div>
			@dialog.Trigger(dialog.TriggerProps{For: "suppressed-contacts-dialog"}) {
				<button type="button" class="inline-flex shrink-0 items-center gap-1.5 rounded-md border border-border px-3 py-2 text-xs font-semibold text-muted-foreground hover:bg-accent hover:text-foreground">
					@icon.List(icon.Props{Class: "size-3.5"})
					Manage
				</button>
			}
		</div>
		@dialog.Dialog(dialog.Props{ID: "suppressed-contacts-dialog"}) {
			@dialog.Content(dialog.ContentProps{Class: "sm:max-w-2xl"}) {
				@dialog.Header() {
					@dialog.Title() { Suppressed contacts }
					@dialog.Description() { These addresses are allowed to stay deleted and will not be recreated by discovery. }
				}
				<div class="space-y-4">
					<div class="flex items-center justify-between gap-4 rounded-lg border border-border/60 bg-background/40 p-3">
						<div class="min-w-0">
							<div class="text-sm font-medium text-foreground">{ fmt.Sprintf("%d", totalCount) } suppressed contacts</div>
							<p class="text-xs text-muted-foreground mt-0.5">Remove one address or clear the full suppression list.</p>
						</div>
						if totalCount > 0 {
							<form hx-post="/api/settings/contacts/suppressed/clear" hx-target="#contacts-suppressed-settings" hx-swap="outerHTML" onsubmit="return confirm('Clear all suppressed contacts? These addresses may be rediscovered later.')">
								<button type="submit" class="inline-flex shrink-0 items-center gap-1.5 rounded-md border border-destructive/30 px-3 py-2 text-xs font-semibold text-destructive hover:bg-destructive/10">
									@icon.Trash2(icon.Props{Class: "size-3.5"})
									Clear all
								</button>
							</form>
						}
					</div>
					if totalCount == 0 {
						<div class="rounded-lg border border-dashed border-border bg-background/40 p-6 text-center text-sm text-muted-foreground">No suppressed contacts.</div>
					} else {
						<div class="max-h-80 overflow-y-auto rounded-lg border border-border/60 bg-background/35">
							for _, contact := range contacts {
								<div class="flex items-center gap-3 border-b border-border/50 px-3 py-2.5 last:border-b-0">
									@ContactAvatar(contact, "size-8 rounded-full text-[10px] font-bold shrink-0", "bg-muted text-muted-foreground")
									<div class="min-w-0 flex-1">
										<div class="truncate text-sm font-medium text-foreground">{ contact.Name }</div>
										<div class="truncate text-xs text-muted-foreground">{ contact.Email }</div>
									</div>
									<form hx-post={ templ.URL(fmt.Sprintf("/api/settings/contacts/suppressed/%s/clear", contact.ID)) } hx-target="#contacts-suppressed-settings" hx-swap="outerHTML">
										<button type="submit" class="inline-flex shrink-0 items-center gap-1.5 rounded-md border border-border px-2.5 py-1.5 text-xs font-semibold text-muted-foreground hover:bg-accent hover:text-foreground">Allow again</button>
									</form>
								</div>
							}
							if totalCount > len(contacts) {
								<div class="px-3 py-2 text-xs text-muted-foreground">Showing { fmt.Sprintf("%d", len(contacts)) } of { fmt.Sprintf("%d", totalCount) } suppressed contacts.</div>
							}
						</div>
					}
				</div>
			}
		}
	</div>
}

templ SettingsAccountsTab(accounts []models.Account) {
	<div class="mt-6 bg-card rounded-lg border p-6 space-y-5">
		<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
			<div class="min-w-0">
				<h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-1">Accounts</h3>
				<p class="text-xs text-muted-foreground leading-relaxed">See which connected services each account provides. Email is available for existing mail accounts; contacts appear when provider sync is enabled.</p>
			</div>
			@dialog.Trigger(dialog.TriggerProps{For: "choose-account-type-dialog"}) {
				@button.Button(button.Props{
					Size:    button.SizeSm,
					Class:   "btn-skeuo shrink-0",
				}) {
					@icon.Plus(icon.Props{Class: "size-4"})
					Add Account
				}
			}
		</div>
		if len(accounts) == 0 {
			@SettingsNoAccounts()
		} else {
			<div class="space-y-3">
				for _, a := range accounts {
					@SettingsAccountCard(a)
				}
			</div>
		}
	</div>
}

templ SettingsSyncTab(settings models.SyncSettings) {
	<div class="mt-6 space-y-6">
		<form id="sync-settings-form" action="/api/settings/sync" method="POST" class="space-y-4">
			<div class="bg-card rounded-lg border p-6">
				<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
					<div class="min-w-0">
						<h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-1">Sync Frequency</h3>
						<p class="text-xs text-muted-foreground leading-relaxed">Controls how often polled folders are checked for changes.</p>
					</div>
					<div class="w-full sm:w-40 shrink-0">
						@selectbox.SelectBox(selectbox.Props{Class: "settings-select"}) {
							@selectbox.Trigger(selectbox.TriggerProps{Name: "sync_interval_minutes", Class: "bg-background", DisableClear: true}) {
								@selectbox.Value(selectbox.ValueProps{Placeholder: "5 minutes"}) {
									{ strconv.Itoa(settings.SyncIntervalMinutes) } min
								}
							}
							@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
								@selectbox.Item(selectbox.ItemProps{Value: "1", Selected: settings.SyncIntervalMinutes == 1}) { 1 minute }
								@selectbox.Item(selectbox.ItemProps{Value: "5", Selected: settings.SyncIntervalMinutes == 5}) { 5 minutes }
								@selectbox.Item(selectbox.ItemProps{Value: "10", Selected: settings.SyncIntervalMinutes == 10}) { 10 minutes }
								@selectbox.Item(selectbox.ItemProps{Value: "15", Selected: settings.SyncIntervalMinutes == 15}) { 15 minutes }
								@selectbox.Item(selectbox.ItemProps{Value: "30", Selected: settings.SyncIntervalMinutes == 30}) { 30 minutes }
							}
						}
					</div>
				</div>
			</div>

			if len(settings.Accounts) > 0 {
				<div class="bg-card rounded-lg border p-6 space-y-5">
					<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
						<div>
							<h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-1">Folder Sync Mode</h3>
							<p class="text-xs text-muted-foreground leading-relaxed">Click a folder to move it between real-time push notifications and periodic polling.</p>
						</div>
						@popover.Root(popover.RootProps{ID: "sync-real-time-note", Class: "shrink-0"}) {
							@popover.Trigger() {
								<button
									type="button"
									class="flex shrink-0 items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-md"
									aria-label="Show real-time sync note"
								>
									@icon.TriangleAlert(icon.Props{Class: "size-3"})
									Real-time note
								</button>
							}
							@popover.Content(popover.ContentProps{Placement: popover.PlacementBottomEnd, ShowArrow: true, Class: "w-80"}) {
								<div class="flex items-start gap-2.5 p-3">
									@icon.TriangleAlert(icon.Props{Class: "size-3.5 text-muted-foreground mt-0.5 shrink-0"})
									<p class="text-xs text-muted-foreground leading-relaxed">
										Each real-time folder holds open a persistent IMAP connection. Most servers limit concurrent connections (typically 5-15). Enabling real-time on too many folders may cause connection errors or prevent new folders from syncing.
									</p>
								</div>
							}
						}
					</div>
					<div id="idle-folders-inputs"></div>
					<div class="space-y-3" data-sync-folders={ strconv.Itoa(settings.SyncIntervalMinutes) }>
						for _, account := range settings.Accounts {
							<div class="rounded-lg border border-border bg-background p-4" data-sync-account-card>
								<div class="flex items-center gap-2.5 mb-4">
									<div class="account-color-marker size-4 shrink-0" style={ accountColorStyle(account.Color) } data-account-marker={ account.AccountID }></div>
									<div class="min-w-0">
										<p class="text-sm font-medium leading-tight truncate">{ account.AccountName }</p>
										<p class="text-xs text-muted-foreground truncate">{ account.AccountEmail }</p>
									</div>
								</div>
								<div class="grid gap-3 md:grid-cols-2">
									<div class="rounded-md border border-border/70 bg-card/60 p-3">
										<div class="flex items-center gap-1.5 mb-2">
											@icon.Zap(icon.Props{Class: "size-3 text-amber-700/70 dark:text-amber-300/70"})
											<span class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider">Real-time</span>
										</div>
										<div class="flex flex-wrap gap-1.5 min-h-[28px]" data-idle-zone={ account.AccountID }>
											for _, f := range account.Folders {
												if f.IsIDLE {
													@syncFolderPill(f, true, settings.SyncIntervalMinutes, account.AccountID)
												}
											}
										</div>
									</div>
									<div class="rounded-md border border-border/70 bg-card/60 p-3">
										<div class="flex items-center gap-1.5 mb-2">
											@icon.Clock(icon.Props{Class: "size-3 text-muted-foreground"})
											<span class="text-[11px] font-semibold text-muted-foreground uppercase tracking-wider">Polling ({ strconv.Itoa(settings.SyncIntervalMinutes) } min)</span>
										</div>
										<div class="flex flex-wrap gap-1.5 min-h-[28px]" data-poll-zone={ account.AccountID }>
											for _, f := range account.Folders {
												if !f.IsIDLE {
													@syncFolderPill(f, false, settings.SyncIntervalMinutes, account.AccountID)
												}
											}
										</div>
									</div>
								</div>
							</div>
						}
					</div>
				</div>
			}

			<div class="flex justify-end pt-2">
					<button
						type="submit"
						id="sync-save-btn"
						disabled
						class="btn-skeuo inline-flex items-center justify-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-lg transition-all duration-200 disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:opacity-40"
					>
						<span class="inline-flex items-center gap-1.5">
							<span class="sync-btn-idle inline-flex items-center gap-1.5">
								@icon.Check(icon.Props{Class: "size-4"})
								Save
							</span>
							<span class="sync-btn-saving hidden items-center gap-1.5">
								<div class="size-4 border-2 border-current/30 border-t-current rounded-full animate-spin"></div>
								Saving
							</span>
							<span class="sync-btn-saved hidden items-center gap-1.5">
								<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path class="sync-check-icon" stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
								Saved
							</span>
							<span class="sync-btn-error hidden items-center gap-1.5">
								<svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path class="sync-x-icon" stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6"/></svg>
								Failed
							</span>
						</span>
					</button>
			</div>
		</form>
	</div>
	<style>
		@keyframes sync-pill-in {
			0% { opacity: 0; transform: scale(0.9); }
			100% { opacity: 1; transform: scale(1); }
		}
		@keyframes sync-pill-out {
			0% { opacity: 1; transform: scale(1); }
			100% { opacity: 0; transform: scale(0.9); }
		}
		.sync-pill-enter { animation: sync-pill-in 220ms ease-out; }
		.sync-pill-exit { animation: sync-pill-out 160ms ease-in forwards; }
		@keyframes check-draw {
			0% { stroke-dashoffset: 24; }
			100% { stroke-dashoffset: 0; }
		}
		@keyframes x-draw {
			0% { stroke-dashoffset: 12; }
			100% { stroke-dashoffset: 0; }
		}
		.sync-check-icon { stroke-dasharray: 24; stroke-dashoffset: 24; animation: check-draw 300ms ease-out 100ms forwards; }
		.sync-x-icon { stroke-dasharray: 12; stroke-dashoffset: 12; animation: x-draw 250ms ease-out 100ms forwards; }
	</style>
	<script>
	(function() {
		function togglePill(pill) {
			if (pill.classList.contains('sync-pill-exit')) return;

			var container = pill.closest('[data-sync-account-card]');
			if (!container) return;
			var idleZone = container.querySelector('[data-idle-zone]');
			var pollZone = container.querySelector('[data-poll-zone]');
			if (!idleZone || !pollZone) return;

			var toIdle = !!pill.closest('[data-poll-zone]');
			var target = toIdle ? idleZone : pollZone;

			pill.classList.add('sync-pill-exit');
			pill.addEventListener('animationend', function onExit() {
				pill.removeEventListener('animationend', onExit);
				pill.classList.remove('sync-pill-exit');

				if (toIdle) {
					pill.className = pill.className.replace(/bg-muted\/50 border-border text-muted-foreground/g, 'bg-amber-800/10 border-amber-700/20 text-amber-800 dark:bg-amber-300/10 dark:border-amber-300/20 dark:text-amber-200');
					pill.querySelector('.sync-label').textContent = 'real-time';
				} else {
					pill.className = pill.className.replace(/bg-amber-800\/10 border-amber-700\/20 text-amber-800 dark:bg-amber-300\/10 dark:border-amber-300\/20 dark:text-amber-200/g, 'bg-muted/50 border-border text-muted-foreground');
					pill.querySelector('.sync-label').textContent = pill.dataset.interval + ' min';
				}

				target.appendChild(pill);
				pill.classList.add('sync-pill-enter');
				pill.addEventListener('animationend', function onEnter() {
					pill.removeEventListener('animationend', onEnter);
					pill.classList.remove('sync-pill-enter');
				});

				updateEmptyStates(container);
				updateHiddenInputs();
			});
		}

		function updateEmptyStates(container) {
			var zones = container
				? container.querySelectorAll('[data-idle-zone],[data-poll-zone]')
				: document.querySelectorAll('[data-idle-zone],[data-poll-zone]');
			zones.forEach(updateZoneEmpty);
		}

		function updateZoneEmpty(zone) {
			var pills = zone.querySelectorAll('[data-sync-pill]');
			var existing = zone.querySelector('.sync-empty-state');
			if (pills.length === 0 && !existing) {
				var el = document.createElement('span');
				el.className = 'sync-empty-state inline-flex items-center px-2.5 rounded-md border border-dashed border-border text-[11px] text-muted-foreground/50';
				el.style.height = '26px';
				el.textContent = 'None selected';
				zone.appendChild(el);
			} else if (pills.length > 0 && existing) {
				existing.remove();
			}
		}

		function updateHiddenInputs() {
			var container = document.getElementById('idle-folders-inputs');
			container.innerHTML = '';
			var seenAccounts = {};
			document.querySelectorAll('[data-idle-zone] [data-role]').forEach(function(pill) {
				var accountID = pill.dataset.accountId;
				var role = pill.dataset.role;
				var input = document.createElement('input');
				input.type = 'hidden';
				input.name = 'idle_folders';
				input.value = accountID + ':' + role;
				container.appendChild(input);
				seenAccounts[accountID] = true;
			});
			document.querySelectorAll('[data-poll-zone]').forEach(function(zone) {
				var accountID = zone.getAttribute('data-poll-zone');
				if (!seenAccounts[accountID]) {
					seenAccounts[accountID] = true;
				}
			});
			for (var aid in seenAccounts) {
				var input = document.createElement('input');
				input.type = 'hidden';
				input.name = 'account_ids';
				input.value = aid;
				container.appendChild(input);
			}
		}

		document.addEventListener('click', function(e) {
			var pill = e.target.closest('[data-sync-pill]');
			if (pill) {
				e.preventDefault();
				togglePill(pill);
				markDirty();
				return;
			}
		});

		function markDirty() {
			var btn = document.getElementById('sync-save-btn');
			if (btn) btn.disabled = false;
		}

		var syncBtnTimer = null;
		function setButtonState(state) {
			var btn = document.getElementById('sync-save-btn');
			if (!btn) return;

			if (syncBtnTimer) { clearTimeout(syncBtnTimer); syncBtnTimer = null; }

			var fromW = btn.offsetWidth;
			btn.style.width = fromW + 'px';

			btn.querySelectorAll('.sync-btn-idle,.sync-btn-saving,.sync-btn-saved,.sync-btn-error').forEach(function(el) {
				el.classList.add('hidden');
				el.classList.remove('inline-flex');
			});
			var target = btn.querySelector('.sync-btn-' + state);
			if (target) { target.classList.remove('hidden'); target.classList.add('inline-flex'); }

			btn.classList.remove('btn-skeuo', 'bg-emerald-600', 'hover:bg-emerald-700', 'text-white', 'bg-destructive', 'hover:bg-destructive/90');
			if (state === 'saved') {
				btn.classList.add('bg-emerald-600', 'hover:bg-emerald-700', 'text-white');
			} else if (state === 'error') {
				btn.classList.add('bg-destructive', 'hover:bg-destructive/90', 'text-white');
			} else {
				btn.classList.add('btn-skeuo');
			}

			btn.disabled = false;

			var toW = btn.scrollWidth;
			btn.style.width = fromW + 'px';

			requestAnimationFrame(function() {
				btn.style.transition = 'width 200ms ease, background-color 200ms ease, opacity 200ms ease, color 200ms ease';
				btn.style.width = toW + 'px';

				syncBtnTimer = setTimeout(function() {
					btn.style.width = '';
					btn.style.transition = '';
					if (state === 'saving') btn.disabled = true;
					syncBtnTimer = null;
				}, 220);
			});
		}

		document.getElementById('sync-settings-form').addEventListener('submit', function(e) {
			e.preventDefault();
			var form = this;
			var btn = document.getElementById('sync-save-btn');
			setButtonState('saving');

			var formData = new FormData(form);
			var params = new URLSearchParams();
			formData.forEach(function(value, key) {
				params.append(key, value);
			});
			fetch('/api/settings/sync', {
				method: 'POST',
				body: params,
				headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' }
			}).then(function(res) {
				if (!res.ok) throw new Error(res.statusText);
				return res.json();
			}).then(function() {
				setButtonState('saved');
				syncBtnTimer = setTimeout(function() {
					setButtonState('idle');
					syncBtnTimer = setTimeout(function() {
						document.getElementById('sync-save-btn').disabled = true;
					}, 220);
				}, 2000);
			}).catch(function() {
				setButtonState('error');
				syncBtnTimer = setTimeout(function() {
					setButtonState('idle');
				}, 3000);
			});
		});

		document.querySelector('#sync-settings-form [data-tui-selectbox-content]')?.addEventListener('click', function() {
			setTimeout(markDirty, 50);
		});

		updateHiddenInputs();
		updateEmptyStates();
	})();
	</script>
}

templ syncFolderPill(f models.FolderSyncStatus, isIDLE bool, interval int, accountID string) {
	<button
		type="button"
		data-sync-pill
		data-role={ f.Role }
		data-account-id={ accountID }
		data-interval={ strconv.Itoa(interval) }
		class={
			"inline-flex items-center gap-1.5 px-2.5 rounded-md border text-xs font-medium cursor-pointer transition-transform hover:scale-[1.02] will-change-transform backface-hidden",
			templ.KV("bg-amber-800/10 border-amber-700/20 text-amber-800 dark:bg-amber-300/10 dark:border-amber-300/20 dark:text-amber-200", isIDLE),
			templ.KV("bg-muted/50 border-border text-muted-foreground", !isIDLE),
		}
		style="height:26px"
	>
		{{ folderIcon := icon.Icon(f.Icon) }}
		@folderIcon(icon.Props{Class: "size-3"})
		{ f.Name }
		<span class="sync-label text-[10px] opacity-70">
			if isIDLE {
				real-time
			} else {
				{ strconv.Itoa(interval) } min
			}
		</span>
	</button>
}

templ SettingsNoAccounts() {
	<div class="flex flex-col items-center justify-center py-10 text-center">
		<div class="size-14 rounded-full bg-muted/50 flex items-center justify-center mb-4">
			@icon.Mail(icon.Props{Class: "size-6 text-muted-foreground"})
		</div>
		<p class="text-sm font-medium text-foreground mb-1">No accounts yet</p>
		<p class="text-xs text-muted-foreground">Add your email account to get started.</p>
	</div>
}

templ SettingsAccountCard(account models.Account) {
	<div id={ fmt.Sprintf("account-card-%s", account.ID) }>
		<div class="rounded-lg border border-border bg-background p-4 shadow-sm">
			<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
				<div class="flex min-w-0 items-start gap-3">
					@AccountColorPopover(account)
					<div class="min-w-0">
						<div class="flex flex-wrap items-center gap-2">
							<p class="min-w-0 truncate text-sm font-semibold text-foreground">{ account.Name }</p>
							<span class="rounded-md border border-border/70 bg-muted/35 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-muted-foreground">{ accountProviderName(account.Provider) }</span>
						</div>
						<p class="mt-0.5 truncate text-xs text-muted-foreground">{ account.Email }</p>
					</div>
				</div>
				<div class="flex flex-wrap items-center gap-2 sm:justify-end">
					if account.IsDeleting {
						<button type="button" class="inline-flex items-center gap-1.5 text-xs text-amber-700 dark:text-amber-400 px-2.5 py-1.5 rounded-md border border-amber-300/40 dark:border-amber-500/30 bg-amber-100/50 dark:bg-amber-500/10 cursor-default" disabled>
							@icon.RefreshCw(icon.Props{Class: "size-3.5 animate-spin"})
							Deleting
						</button>
					} else {
						<button
							class="account-action-btn inline-flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground transition-colors px-2.5 py-1.5 rounded-md border border-border"
							hx-get={ fmt.Sprintf("/api/accounts/%s/edit", account.ID) }
							hx-target="#edit-account-container"
							hx-swap="innerHTML"
						>
							@icon.Pencil(icon.Props{Class: "size-3.5"})
							Edit
						</button>
						<button
							id={ fmt.Sprintf("test-btn-%s", account.ID) }
							data-test-btn
							data-account-id={ account.ID }
							class="account-action-btn inline-flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground transition-all duration-300 px-2.5 py-1.5 rounded-md border border-border"
							hx-post={ fmt.Sprintf("/api/accounts/%s/test", account.ID) }
							hx-swap="none"
						>
							<span data-test-btn-content class="inline-flex items-center gap-1.5">
								@icon.Wifi(icon.Props{Class: "size-3.5"})
								Test
							</span>
						</button>
						if account.Provider == "gmail" {
							@GmailReauthForm(account)
						}
						@dialog.Trigger(dialog.TriggerProps{For: fmt.Sprintf("delete-account-%s", account.ID)}) {
							<button
								type="button"
								class="account-action-btn account-action-btn-danger inline-flex items-center gap-1.5 text-xs text-muted-foreground hover:text-destructive transition-colors px-2.5 py-1.5 rounded-md border border-border hover:border-destructive/30"
							>
								@icon.Trash2(icon.Props{Class: "size-3.5"})
								Delete
							</button>
						}
					}
				</div>
			</div>
			<div class="mt-4 space-y-2 border-t border-border/60 pt-3">
				@AccountServiceToggle(account, "email", "Email", "Fetch new messages and keep mail folders up to date.", account.EmailSyncEnabled, true)
				@AccountServiceToggle(account, "contacts", "Contacts", accountContactSyncToggleDescription(account), account.ContactSyncEnabled, accountContactSyncConfigurable(account))
			</div>
		</div>
		@dialog.Dialog(dialog.Props{ID: fmt.Sprintf("delete-account-%s", account.ID)}) {
			@dialog.Content(dialog.ContentProps{Class: "sm:max-w-md"}) {
				@dialog.Header() {
					@dialog.Title() {
						Delete Account
					}
					@dialog.Description() {
						This will remove <strong>{ account.Email }</strong> and all its synced messages. This action cannot be undone.
					}
				}
				<div class="flex items-center gap-3 p-3 rounded-lg bg-destructive/5 border border-destructive/15">
					<div class="account-color-marker size-5 shrink-0" style={ accountColorStyle(account.Color) } data-account-marker={ account.ID }></div>
					<div class="flex-1 min-w-0">
						<p class="text-sm font-medium truncate">{ account.Name }</p>
						<p class="text-xs text-muted-foreground truncate">{ account.Email }</p>
					</div>
				</div>
				@dialog.Footer() {
					@dialog.Close() {
						<button
							type="button"
							class="inline-flex items-center justify-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg border border-border hover:bg-accent transition-colors"
						>
							Cancel
						</button>
					}
					<button
						type="button"
						class="inline-flex items-center justify-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-destructive text-white hover:bg-destructive/90 transition-colors"
						hx-delete={ fmt.Sprintf("/api/accounts/%s", account.ID) }
						hx-swap="none"
						data-delete-account-action="true"
						data-account-id={ account.ID }
					>
						@icon.Trash2(icon.Props{Class: "size-4"})
						Delete Account
					</button>
				}
			}
		}
	</div>
}
templ AccountServiceToggle(account models.Account, service string, label string, description string, enabled bool, configurable bool) {
	<form
		hx-post={ fmt.Sprintf("/api/accounts/%s/services", account.ID) }
		hx-target={ fmt.Sprintf("#account-card-%s", account.ID) }
		hx-swap="outerHTML"
		class={
			"flex items-center gap-3 rounded-md border border-border/70 bg-card/60 px-3 py-2.5",
			templ.KV("opacity-60", !configurable),
		}
	>
		<input type="hidden" name="service" value={ service }/>
		<span class="flex size-8 shrink-0 items-center justify-center rounded-md border border-border/60 bg-background text-muted-foreground">
			if service == "email" {
				@icon.Mail(icon.Props{Class: "size-4"})
			} else {
				@icon.Users(icon.Props{Class: "size-4"})
			}
		</span>
		<div class="min-w-0 flex-1">
			<div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-xs font-semibold text-foreground">
				<span>{ label }</span>
				if service == "contacts" && account.ContactSyncEnabled {
					<span class="font-medium text-muted-foreground">{ contactProviderLabel(account) }</span>
				}
			</div>
			<p class="mt-0.5 truncate text-[11px] text-muted-foreground">{ description }</p>
		</div>
		<div class="flex shrink-0 items-center gap-2">
			<span class="w-6 text-right text-[11px] font-semibold text-muted-foreground">{ serviceStateLabel(enabled) }</span>
			@switchcomp.Switch(switchcomp.Props{
				ID:       fmt.Sprintf("account-%s-%s-sync", account.ID, service),
				Name:     "enabled",
				Value:    "true",
				Checked:  enabled,
				Disabled: !configurable,
				Attributes: templ.Attributes{
					"onchange":   "this.form.requestSubmit()",
					"aria-label": fmt.Sprintf("Toggle %s for %s", label, account.Email),
				},
			})
		</div>
	</form>
}

func serviceStateLabel(enabled bool) string {
	if enabled {
		return "On"
	}
	return "Off"
}

func accountContactSyncConfigurable(account models.Account) bool {
	return strings.TrimSpace(account.Provider) == "gmail" || strings.TrimSpace(account.ContactSyncProvider) != ""
}

func accountContactSyncToggleDescription(account models.Account) string {
	if accountContactSyncConfigurable(account) {
		return "Pull provider contacts into Gofer."
	}
	return "Configure contacts in Edit first."
}

func accountProviderName(provider string) string {
	switch strings.TrimSpace(provider) {
	case "gmail":
		return "Gmail"
	default:
		return "IMAP"
	}
}

templ AccountColorPopover(account models.Account) {
	@popover.Root(popover.RootProps{ID: fmt.Sprintf("account-color-%s", account.ID), Class: "shrink-0"}) {
		@popover.Trigger() {
			<button
				type="button"
				class="account-color-marker size-5 shrink-0 cursor-pointer ring-2 ring-transparent ring-offset-2 ring-offset-background transition-[box-shadow,filter] hover:brightness-110 hover:ring-border focus-visible:outline-none focus-visible:ring-ring"
				style={ accountColorStyle(account.Color) }
				data-account-marker={ account.ID }
				aria-label={ fmt.Sprintf("Change marker color for %s", account.Name) }
			></button>
		}
		@popover.Content(popover.ContentProps{Placement: popover.PlacementBottomStart, ShowArrow: true, Class: "w-64"}) {
			<div class="p-3" data-account-color-picker data-account-id={ account.ID }>
				<div class="mb-3 flex items-start justify-between gap-3">
					<div class="min-w-0">
						<p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Marker color</p>
						<p class="mt-0.5 truncate text-sm font-medium text-popover-foreground">{ account.Name }</p>
					</div>
					<div class="account-color-marker size-6 shrink-0" style={ accountColorStyle(account.Color) } data-account-marker={ account.ID }></div>
				</div>
				<div class="grid grid-cols-6 gap-2">
					for _, color := range accountColorOptions() {
						<button
							type="button"
							class="account-color-swatch size-7 rounded-full transition-transform hover:scale-110 focus-visible:outline-none"
							style={ accountColorStyle(color) }
							data-account-color-option={ color }
							data-account-color-active={ fmt.Sprintf("%t", accountColorSelected(account.Color, color)) }
							aria-label={ fmt.Sprintf("Use %s", color) }
							aria-pressed={ fmt.Sprintf("%t", accountColorSelected(account.Color, color)) }
						></button>
					}
				</div>
				<div class="mt-3 flex items-center gap-2 rounded-md border border-border/70 bg-background/50 px-2.5 py-2">
					<label for={ fmt.Sprintf("account-color-custom-%s", account.ID) } class="text-xs font-medium text-muted-foreground">Custom</label>
					<input
						id={ fmt.Sprintf("account-color-custom-%s", account.ID) }
						type="color"
						value={ accountColorValue(account.Color) }
						class="h-7 w-9 cursor-pointer rounded border border-border bg-transparent p-0.5"
						data-account-color-custom
					/>
					<span class="ml-auto text-xs text-muted-foreground" data-account-color-status></span>
					</div>
				</div>
			}
		}
}

templ AccountSignaturesSettings(accounts []models.AccountSignatureData) {
	<div class="bg-card rounded-lg border p-6">
		<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
			<div class="min-w-0">
				<h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-1">Signatures</h3>
				<p class="text-xs text-muted-foreground">Create reusable signatures and choose which accounts use them for new messages, replies, and forwards.</p>
				<div class="mt-3 flex flex-wrap gap-2 text-xs text-muted-foreground">
					<span class="inline-flex items-center gap-1.5 rounded-md border border-border bg-background px-2 py-1">
						@icon.Signature(icon.Props{Class: "size-3"})
						{ strconv.Itoa(signatureTotal(accounts)) } total
					</span>
				</div>
			</div>
			@dialog.Trigger(dialog.TriggerProps{For: "compose-signatures-dialog"}) {
				<button type="button" class="btn-skeuo inline-flex shrink-0 items-center justify-center gap-1.5 rounded-lg px-4 py-2 text-sm font-semibold">
					@icon.Signature(icon.Props{Class: "size-4"})
					Manage Signatures
				</button>
			}
		</div>
	</div>
	<div id="compose-signatures-dialog-container">
		@ComposeSignaturesDialog(accounts)
	</div>
}

templ ComposeSignaturesDialog(accounts []models.AccountSignatureData) {
	@dialog.Dialog(dialog.Props{ID: "compose-signatures-dialog"}) {
		@dialog.Content(dialog.ContentProps{Class: "sm:max-w-5xl max-h-[calc(100vh-2rem)] overflow-y-auto overflow-x-hidden"}) {
			@dialog.Header() {
				@dialog.Title() {
					Signatures
				}
				@dialog.Description() {
					Manage your reusable signatures and account assignments.
				}
			}
			@ComposeSignaturesManager(accounts)
		}
	}
}

templ ComposeSignaturesManager(accounts []models.AccountSignatureData) {
	<div id="compose-signatures-manager" class="min-w-0" data-account-signatures-manager data-refresh-url="/api/settings/signatures/manage" data-refresh-target="#compose-signatures-manager" data-refresh-swap="outerHTML">
		@SignatureManagerGrid(accounts)
	</div>
}

templ SignatureManagerGrid(accounts []models.AccountSignatureData) {
	if len(accounts) == 0 {
		<div class="rounded-lg border border-dashed border-border p-6 text-center text-sm text-muted-foreground">Add an account before configuring signatures.</div>
	} else {
		{{ first := accounts[0] }}
		<div class="grid min-w-0 gap-5 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
			<div class="min-w-0 space-y-4">
				@SignatureLibrary(first)
			</div>
			<div class="min-w-0 rounded-lg border border-border bg-background/60 p-4 space-y-4">
				<div class="space-y-2">
					<label class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Account</label>
					@selectbox.SelectBox(selectbox.Props{Class: "settings-select"}) {
						@selectbox.Trigger(selectbox.TriggerProps{Name: "signature_account_id", Class: "bg-background", DisableClear: true, Attributes: templ.Attributes{"data-signature-account-select": ""}}) {
							<span class="flex min-w-0 flex-1 items-center gap-2">
								<span class="account-color-marker size-3.5 shrink-0" style={ accountColorStyle(first.Account.Color) } data-signature-account-marker data-account-marker={ first.Account.ID }></span>
								@selectbox.Value(selectbox.ValueProps{Placeholder: "Choose account", Class: "min-w-0 text-left"}) {
									{ first.Account.Name } &lt;{ first.Account.Email }&gt;
								}
							</span>
						}
						@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
							for _, data := range accounts {
								@selectbox.Item(selectbox.ItemProps{Value: data.Account.ID, Selected: data.Account.ID == first.Account.ID}) {
									<span class="inline-flex min-w-0 items-center gap-2">
										<span class="account-color-marker size-3.5 shrink-0" style={ accountColorStyle(data.Account.Color) } data-signature-account-marker-source data-account-marker={ data.Account.ID }></span>
										<span class="truncate">{ data.Account.Name } &lt;{ data.Account.Email }&gt;</span>
									</span>
								}
							}
						}
					}
				</div>
				<div class="grid" data-signature-account-panels>
					for _, data := range accounts {
						<form class={ "col-start-1 row-start-1 space-y-4", templ.KV("invisible pointer-events-none", data.Account.ID != first.Account.ID) } data-account-signature-settings data-account-id={ data.Account.ID } aria-hidden={ strconv.FormatBool(data.Account.ID != first.Account.ID) }>
							@AccountSignatureAssignmentRow("new", "New messages", data.Settings.NewEnabled, data.Settings.NewSignatureID, "", data.Signatures)
							@AccountSignatureAssignmentRow("reply", "Replies", data.Settings.ReplyEnabled, data.Settings.ReplySignatureID, data.Settings.ReplyPlacement, data.Signatures)
							@AccountSignatureAssignmentRow("forward", "Forwards", data.Settings.ForwardEnabled, data.Settings.ForwardSignatureID, data.Settings.ForwardPlacement, data.Signatures)
							<div class="flex items-center justify-between gap-3 pt-1">
								<span class="text-xs text-muted-foreground" data-signature-settings-status></span>
								<button type="submit" class="btn-skeuo inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm font-semibold">
									@icon.Check(icon.Props{Class: "size-3.5"})
									Save
								</button>
							</div>
						</form>
					}
				</div>
			</div>
		</div>
	}
}

templ SignatureLibrary(data models.AccountSignatureData) {
	<div class="min-w-0 rounded-lg border border-border bg-background/60 p-4 space-y-3">
		<div class="flex items-center justify-between gap-3">
			<div>
				<h4 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Signature library</h4>
				<p class="text-xs text-muted-foreground mt-1">These signatures can be assigned to any account.</p>
			</div>
		</div>
		<div class="flex items-end gap-2">
			<div class="min-w-0 flex-1 space-y-1.5">
				<label class="text-xs font-medium text-muted-foreground">Saved signatures</label>
				@selectbox.SelectBox(selectbox.Props{Class: "settings-select"}) {
					@selectbox.Trigger(selectbox.TriggerProps{Name: "signature_picker_id", Class: "bg-background", DisableClear: true, Attributes: templ.Attributes{"data-signature-select": ""}}) {
						@selectbox.Value(selectbox.ValueProps{Placeholder: "Select signature"})
					}
					@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
						if len(data.Signatures) == 0 {
							@selectbox.Item(selectbox.ItemProps{Value: "", Selected: true, Disabled: true}) { No signatures yet }
						} else {
							@selectbox.Item(selectbox.ItemProps{Value: "", Selected: true}) { Select signature }
							for _, sig := range data.Signatures {
								@selectbox.Item(selectbox.ItemProps{Value: sig.ID, Attributes: templ.Attributes{"data-signature-option": "", "data-signature-name": sig.Name, "data-signature-html": sig.HTMLBody}}) { { sig.Name } }
							}
						}
					}
				}
			</div>
			<button type="button" class="inline-flex h-9 shrink-0 items-center gap-1.5 rounded-md border border-border px-2.5 text-xs text-muted-foreground hover:bg-accent hover:text-foreground" data-signature-new>
				@icon.Plus(icon.Props{Class: "size-3.5"})
				New
			</button>
		</div>
		<form data-signature-form class="space-y-3">
			<input type="hidden" name="id" value="" data-signature-id/>
			<div>
				<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Name</label>
				@input.Input(input.Props{Name: "name", Type: input.TypeText, Placeholder: "Work, Personal, Support...", Attributes: templ.Attributes{"data-signature-name": ""}})
			</div>
			<div>
				<div class="mb-1.5 flex items-center justify-between gap-3">
					<label class="text-xs font-medium text-muted-foreground">Signature</label>
					<div class="inline-flex shrink-0 rounded-[var(--radius)] border border-border bg-background p-0.5 text-[11px]" data-signature-editor-mode>
						<button type="button" class="rounded-[calc(var(--radius)-2px)] px-2 py-0.5 font-medium text-foreground bg-card shadow-sm" data-signature-mode-button="visual">Rendered</button>
						<button type="button" class="rounded-[calc(var(--radius)-2px)] px-2 py-0.5 font-medium text-muted-foreground hover:text-foreground" data-signature-mode-button="source">HTML</button>
					</div>
				</div>
				<textarea name="html_body" class="hidden" data-signature-html></textarea>
				<div class="min-h-28 max-w-full overflow-x-auto rounded-md border border-border bg-card px-3 py-2 text-sm leading-6 outline-none focus:ring-2 focus:ring-ring" contenteditable="true" role="textbox" data-signature-editor data-placeholder="Write your signature..." oninput="syncSignatureEditor(this)"></div>
				<textarea class="hidden min-h-28 w-full resize-y rounded-md border border-border bg-card px-3 py-2 font-mono text-xs leading-5 text-foreground outline-none focus:ring-2 focus:ring-ring" spellcheck="false" placeholder="Paste full HTML here, then switch back to Rendered to preview it." data-signature-source></textarea>
				<p class="text-[11px] text-muted-foreground mt-1">Use Rendered for normal editing or HTML to paste source. Unsafe tags are stripped when rendered and saved.</p>
			</div>
			<div class="flex items-center justify-between gap-3">
				<span class="text-xs text-muted-foreground" data-signature-save-status></span>
				<div class="flex items-center gap-2">
					<button type="button" class="inline-flex items-center gap-1.5 rounded-md border border-border px-2.5 py-1.5 text-xs text-muted-foreground hover:border-destructive/30 hover:text-destructive" data-signature-delete-current>Delete</button>
					<button type="submit" class="btn-skeuo inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm font-semibold">
						@icon.Save(icon.Props{Class: "size-3.5"})
						Save Signature
					</button>
				</div>
			</div>
		</form>
	</div>
}

templ AccountSignaturesDialog(data models.AccountSignatureData) {
	@dialog.Dialog(dialog.Props{ID: "account-signatures-dialog"}) {
		@dialog.Content(dialog.ContentProps{Class: "sm:max-w-3xl"}) {
			@dialog.Header() {
				@dialog.Title() {
					Account Signatures
				}
				@dialog.Description() {
					Manage shared signatures and choose when { data.Account.Email } uses them.
				}
			}
			<div class="grid min-w-0 gap-5 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]" data-account-signatures-manager data-account-id={ data.Account.ID }>
				<div class="min-w-0 space-y-4">
					<div class="min-w-0 rounded-lg border border-border bg-background/60 p-4 space-y-3">
						<div class="flex items-center justify-between gap-3">
							<div>
								<h3 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Signature library</h3>
								<p class="text-xs text-muted-foreground mt-1">Create reusable signatures that any account can use.</p>
							</div>
						</div>
						<div class="flex items-end gap-2">
							<div class="min-w-0 flex-1 space-y-1.5">
								<label class="text-xs font-medium text-muted-foreground">Saved signatures</label>
								@selectbox.SelectBox(selectbox.Props{Class: "settings-select"}) {
									@selectbox.Trigger(selectbox.TriggerProps{Name: "signature_picker_id", Class: "bg-background", DisableClear: true, Attributes: templ.Attributes{"data-signature-select": ""}}) {
										@selectbox.Value(selectbox.ValueProps{Placeholder: "Select signature"})
									}
									@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
										if len(data.Signatures) == 0 {
											@selectbox.Item(selectbox.ItemProps{Value: "", Selected: true, Disabled: true}) { No signatures yet }
										} else {
											@selectbox.Item(selectbox.ItemProps{Value: "", Selected: true}) { Select signature }
											for _, sig := range data.Signatures {
												@selectbox.Item(selectbox.ItemProps{Value: sig.ID, Attributes: templ.Attributes{"data-signature-option": "", "data-signature-name": sig.Name, "data-signature-html": sig.HTMLBody}}) { { sig.Name } }
											}
										}
									}
								}
							</div>
							<button type="button" class="inline-flex h-9 shrink-0 items-center gap-1.5 rounded-md border border-border px-2.5 text-xs text-muted-foreground hover:bg-accent hover:text-foreground" data-signature-new>
								@icon.Plus(icon.Props{Class: "size-3.5"})
								New
							</button>
						</div>
						<form data-signature-form class="space-y-3">
							<input type="hidden" name="id" value="" data-signature-id/>
							<div>
								<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Name</label>
								@input.Input(input.Props{Name: "name", Type: input.TypeText, Placeholder: "Work, Personal, Support...", Attributes: templ.Attributes{"data-signature-name": ""}})
							</div>
							<div>
								<div class="mb-1.5 flex items-center justify-between gap-3">
									<label class="text-xs font-medium text-muted-foreground">Signature</label>
									<div class="inline-flex shrink-0 rounded-[var(--radius)] border border-border bg-background p-0.5 text-[11px]" data-signature-editor-mode>
										<button type="button" class="rounded-[calc(var(--radius)-2px)] px-2 py-0.5 font-medium text-foreground bg-card shadow-sm" data-signature-mode-button="visual">Rendered</button>
										<button type="button" class="rounded-[calc(var(--radius)-2px)] px-2 py-0.5 font-medium text-muted-foreground hover:text-foreground" data-signature-mode-button="source">HTML</button>
									</div>
								</div>
								<textarea name="html_body" class="hidden" data-signature-html></textarea>
								<div class="min-h-28 max-w-full overflow-x-auto rounded-md border border-border bg-card px-3 py-2 text-sm leading-6 outline-none focus:ring-2 focus:ring-ring" contenteditable="true" role="textbox" data-signature-editor data-placeholder="Write your signature..." oninput="syncSignatureEditor(this)"></div>
								<textarea class="hidden min-h-28 w-full resize-y rounded-md border border-border bg-card px-3 py-2 font-mono text-xs leading-5 text-foreground outline-none focus:ring-2 focus:ring-ring" spellcheck="false" placeholder="Paste full HTML here, then switch back to Rendered to preview it." data-signature-source></textarea>
								<p class="text-[11px] text-muted-foreground mt-1">Use Rendered for normal editing or HTML to paste source. Unsafe tags are stripped when rendered and saved.</p>
							</div>
							<div class="flex items-center justify-between gap-3">
								<span class="text-xs text-muted-foreground" data-signature-save-status></span>
								<div class="flex items-center gap-2">
									<button type="button" class="inline-flex items-center gap-1.5 rounded-md border border-border px-2.5 py-1.5 text-xs text-muted-foreground hover:border-destructive/30 hover:text-destructive" data-signature-delete-current>Delete</button>
									<button type="submit" class="btn-skeuo inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm font-semibold">
										@icon.Save(icon.Props{Class: "size-3.5"})
										Save Signature
									</button>
								</div>
							</div>
						</form>
					</div>
				</div>

				<form class="rounded-lg border border-border bg-background/60 p-4 space-y-4" data-account-signature-settings>
					<div>
						<h3 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Use on this account</h3>
						<p class="text-xs text-muted-foreground mt-1">Choose when signatures are automatically inserted.</p>
					</div>
					@AccountSignatureAssignmentRow("new", "New messages", data.Settings.NewEnabled, data.Settings.NewSignatureID, "", data.Signatures)
					@AccountSignatureAssignmentRow("reply", "Replies", data.Settings.ReplyEnabled, data.Settings.ReplySignatureID, data.Settings.ReplyPlacement, data.Signatures)
					@AccountSignatureAssignmentRow("forward", "Forwards", data.Settings.ForwardEnabled, data.Settings.ForwardSignatureID, data.Settings.ForwardPlacement, data.Signatures)
					<div class="flex items-center justify-between gap-3 pt-2">
						<span class="text-xs text-muted-foreground" data-signature-settings-status></span>
						<button type="submit" class="btn-skeuo inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-sm font-semibold">
							@icon.Check(icon.Props{Class: "size-3.5"})
							Save Assignments
						</button>
					</div>
				</form>
			</div>
		}
	}
}

templ AccountSignatureAssignmentRow(kind string, label string, enabled bool, selectedID string, placement string, signatures []models.Signature) {
	<div class="rounded-md border border-border/70 bg-card/60 p-3 space-y-2">
		<label class="flex items-center gap-2 text-sm font-medium text-foreground">
			@checkbox.Checkbox(checkbox.Props{Name: kind + "_enabled", Value: "true", Checked: enabled})
			{ label }
		</label>
		@selectbox.SelectBox(selectbox.Props{Class: "settings-select"}) {
			@selectbox.Trigger(selectbox.TriggerProps{Name: kind + "_signature_id", Class: "bg-background"}) {
				@selectbox.Value(selectbox.ValueProps{Placeholder: "No signature"}) {
					{ signatureName(signatures, selectedID) }
				}
			}
			@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
				@selectbox.Item(selectbox.ItemProps{Value: "", Selected: selectedID == ""}) { No signature }
				for _, sig := range signatures {
					@selectbox.Item(selectbox.ItemProps{Value: sig.ID, Selected: selectedID == sig.ID}) { { sig.Name } }
				}
			}
		}
		if kind != "new" {
			<div class="grid gap-1.5">
				<label class="text-[11px] font-medium text-muted-foreground">Place signature</label>
				@selectbox.SelectBox(selectbox.Props{Class: "settings-select"}) {
					@selectbox.Trigger(selectbox.TriggerProps{Name: kind + "_placement", Class: "bg-background", DisableClear: true}) {
						@selectbox.Value(selectbox.ValueProps{Placeholder: "Before quoted content"}) {
							if placement == "after" {
								After quoted content
							} else {
								Before quoted content
							}
						}
					}
					@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
						@selectbox.Item(selectbox.ItemProps{Value: "before", Selected: placement != "after"}) { Before quoted content }
						@selectbox.Item(selectbox.ItemProps{Value: "after", Selected: placement == "after"}) { After quoted content }
					}
				}
			</div>
		}
	</div>
}

templ ChooseAccountTypeDialog() {
	@dialog.Dialog(dialog.Props{ID: "choose-account-type-dialog"}) {
		@dialog.Content(dialog.ContentProps{Class: "sm:max-w-md"}) {
			@dialog.Header() {
				@dialog.Title() {
					Add Account
				}
				@dialog.Description() {
					Choose your email provider
				}
			}
		<div class="space-y-3 px-1 pt-2 pb-4">
				<button type="button" onclick="if(window.tui&&window.tui.dialog){window.tui.dialog.close('choose-account-type-dialog')}setTimeout(function(){if(window.tui&&window.tui.dialog)window.tui.dialog.open('add-account-dialog')},150)" class="w-full group flex items-center gap-4 p-4 rounded-lg border border-border hover:border-primary/50 hover:bg-accent/50 transition-all duration-200 text-left">
					<div class="flex items-center justify-center w-10 h-10 rounded-lg bg-accent text-muted-foreground group-hover:text-foreground transition-colors">
						<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect width="20" height="16" x="2" y="4" rx="2"/>
							<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
						</svg>
					</div>
					<div class="flex-1 min-w-0">
						<div class="text-sm font-medium text-foreground">IMAP / SMTP</div>
						<div class="text-xs text-muted-foreground mt-0.5">Any provider with manual server settings</div>
					</div>
					<svg class="size-4 text-muted-foreground group-hover:text-foreground transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
				</button>
				<button type="button" onclick="if(window.tui&&window.tui.dialog){window.tui.dialog.close('choose-account-type-dialog')}setTimeout(function(){if(window.tui&&window.tui.dialog)window.tui.dialog.open('gmail-account-dialog')},150)" class="w-full group flex items-center gap-4 p-4 rounded-lg border border-border hover:border-primary/50 hover:bg-accent/50 transition-all duration-200 text-left">
					<div class="flex items-center justify-center w-10 h-10 rounded-lg bg-accent text-muted-foreground group-hover:text-foreground transition-colors">
						<svg class="size-5" viewBox="0 0 24 24">
							<path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="currentColor" opacity="0.8"/>
							<path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="currentColor" opacity="0.6"/>
							<path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="currentColor" opacity="0.4"/>
							<path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="currentColor" opacity="0.9"/>
						</svg>
					</div>
					<div class="flex-1 min-w-0">
						<div class="text-sm font-medium text-foreground">Gmail</div>
						<div class="text-xs text-muted-foreground mt-0.5">Sign in with Google for instant setup</div>
					</div>
					<svg class="size-4 text-muted-foreground group-hover:text-foreground transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
				</button>
			</div>
		}
	}
}

templ GmailAccountDialog() {
	@dialog.Dialog(dialog.Props{ID: "gmail-account-dialog"}) {
		@dialog.Content(dialog.ContentProps{Class: "sm:max-w-sm"}) {
			@dialog.Header() {
				@dialog.Title() {
					Connect Gmail
				}
				@dialog.Description() {
					Authorize Gofer to access your Gmail account
				}
			}
			<form id="gmail-form" method="POST" action="/api/accounts/oauth2/authorize" class="px-1 pt-2 pb-4 space-y-4">
				<div>
					<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Email Address</label>
					@input.Input(input.Props{
						Name:        "email_address",
						Type:        input.TypeEmail,
						Placeholder: "you@gmail.com",
						Required:    true,
					})
				</div>
				<div>
					<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Display Name</label>
					@input.Input(input.Props{
						Name:        "display_name",
						Type:        input.TypeText,
						Placeholder: "Your Name",
					})
				</div>
				<input type="hidden" name="imap_host" value="imap.gmail.com"/>
				<input type="hidden" name="imap_port" value="993"/>
				<input type="hidden" name="imap_tls_mode" value="tls"/>
				<input type="hidden" name="smtp_host" value="smtp.gmail.com"/>
				<input type="hidden" name="smtp_port" value="465"/>
				<input type="hidden" name="smtp_tls_mode" value="tls"/>
				<input type="hidden" name="auth_method" value="oauth2"/>
				<input type="hidden" name="provider" value="gmail"/>
				<input type="hidden" name="username" value=""/>
				<input type="hidden" name="password" value="_oauth2_"/>
				<hr class="border-border"/>
				<div class="rounded-lg bg-accent/50 border border-border p-3">
					<div class="flex items-start gap-2.5">
						<svg class="size-4 text-muted-foreground mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
						<p class="text-xs text-muted-foreground leading-relaxed">You will be redirected to Google to grant Gofer access to read and send email on your behalf.</p>
					</div>
				</div>
				<button type="submit" class="w-full inline-flex items-center justify-center gap-2.5 text-sm font-medium px-4 py-2.5 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
					<svg class="w-4 h-4" viewBox="0 0 24 24">
						<path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
						<path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
						<path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
						<path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
					</svg>
					Continue with Google
				</button>
			</form>
			<script>
				document.getElementById('gmail-form').addEventListener('submit', function(e) {
					var email = this.querySelector('input[name="email_address"]');
					var username = this.querySelector('input[name="username"]');
					if (email && username) username.value = email.value;
				});
			</script>
		}
	}
}

templ AddAccountDialog() {
	@dialog.Dialog(dialog.Props{ID: "add-account-dialog"}) {
		@dialog.Trigger() {
			<span></span>
		}
		@dialog.Content(dialog.ContentProps{Class: "account-wizard-dialog sm:max-w-4xl"}) {
			@dialog.Header() {
				@dialog.Title() {
					Add Account
				}
				@dialog.Description() {
					Connect mail first, then optionally add contact sync.
				}
			}
			@selectbox.Script()
			<style>
				.account-wizard-section { border:1px solid var(--border); border-radius:var(--radius); background:color-mix(in srgb, var(--background) 55%, transparent); padding:.4rem; transition:background .16s ease,border-color .16s ease,box-shadow .16s ease; }
				.account-wizard-section[data-active="true"] { border-color:color-mix(in srgb, var(--primary) 38%, var(--border)); background:var(--card); box-shadow:0 1px 0 var(--border); }
				.account-wizard-section + .account-wizard-section { margin-top:.5rem; }
				.account-wizard-section-heading { display:flex; width:100%; align-items:flex-start; gap:.75rem; border-radius:calc(var(--radius) * .75); border:1px solid transparent; padding:.65rem; text-align:left; color:var(--foreground); transition:background .16s ease,border-color .16s ease,color .16s ease,opacity .16s ease; }
				.account-wizard-section-title { flex:1; min-width:0; display:flex; align-items:flex-start; gap:.75rem; border-radius:calc(var(--radius) * .75); text-align:left; }
				.account-wizard-section-heading:hover:not(:disabled) { background:var(--accent); color:var(--accent-foreground); }
				.account-wizard-section-heading[data-active="true"] { border-color:var(--border); background:var(--background); }
				.account-wizard-section-heading:disabled { cursor:not-allowed; opacity:.5; }
				.account-wizard-step { display:flex; width:100%; align-items:flex-start; gap:.65rem; border-radius:calc(var(--radius) * .75); border:1px solid transparent; padding:.55rem .6rem; text-align:left; color:var(--muted-foreground); transition:background .16s ease,border-color .16s ease,color .16s ease,opacity .16s ease; }
				.account-wizard-step:hover:not(:disabled) { background:var(--accent); color:var(--accent-foreground); }
				.account-wizard-step[data-active="true"] { border-color:var(--border); background:var(--background); color:var(--foreground); }
				.account-wizard-step:disabled { cursor:not-allowed; opacity:.5; }
				.account-wizard-substeps { display:grid; gap:.25rem; margin:.15rem 0 .1rem 1.15rem; border-left:1px solid var(--border); padding-left:.55rem; }
				.account-wizard-index { display:flex; height:1.5rem; min-width:1.5rem; flex-shrink:0; align-items:center; justify-content:center; border-radius:calc(var(--radius) * .75); background:var(--muted); padding:0 .35rem; font-size:.7rem; font-weight:800; color:var(--muted-foreground); }
				.account-wizard-section[data-active="true"] > .account-wizard-section-heading .account-wizard-index,
				.account-wizard-section-heading[data-active="true"] .account-wizard-index,
				.account-wizard-step[data-active="true"] .account-wizard-index { background:var(--primary); color:var(--primary-foreground); }
				.account-wizard-viewport { min-height:0; height:100%; overflow:hidden; }
				.account-wizard-viewport > .flex { height:100%; align-items:stretch; }
				.account-wizard-viewport [data-wizard-step] { min-height:0; height:100%; }
				.account-wizard-dialog [data-tui-dialog-panel] { height:calc(100vh - 2rem); max-height:calc(100vh - 2rem); grid-template-rows:auto minmax(0,1fr) auto; }
				.account-wizard-shell { min-height:0; height:100%; grid-template-rows:auto minmax(0,1fr); }
				@media (min-width: 768px) { .account-wizard-shell { grid-template-rows:minmax(0,1fr); } }
				.account-wizard-shell > aside { min-height:0; height:100%; overflow-y:auto; }
				.account-wizard-panel { display:flex; height:100%; min-height:0; flex-direction:column; overflow:hidden; padding-right:.25rem; }
				.account-wizard-scroll { flex:1; min-height:0; overflow-y:auto; padding:6px calc(.25rem + 6px) calc(1rem + 6px) 6px; }
				.account-wizard-sticky-header { position:sticky; top:-6px; z-index:20; margin:-6px -6px 1rem; padding:6px 6px .75rem; background:var(--card); box-shadow:0 1px 0 color-mix(in oklab, var(--border) 70%, transparent); }
				.account-wizard-controls { flex-shrink:0; margin-top:.5rem; border-top:1px solid var(--border); background:var(--card); padding-top:.75rem; padding-bottom:2px; }
				.account-wizard-panel .account-wizard-controls { display:none; }
				.account-wizard-card-footer { min-height:3.25rem; border-top:1px solid var(--border); background:var(--card); padding-top:.75rem; padding-bottom:2px; transition:opacity .12s ease; }
				.account-wizard-card-footer[data-switching="true"] { opacity:0; pointer-events:none; }
				.account-wizard-card-footer > [data-wizard-footer-step] { display:none !important; }
				.account-wizard-card-footer > [data-wizard-footer-step][data-active="true"] { display:flex !important; }
			</style>
			<script>
				var _wizStep = 0;
				var _wizardFooterTimers = {};
				function setWizardFooter(root, step, immediate) {
					if (!root) return;
					var footer = root.querySelector('.account-wizard-card-footer');
					if (!footer) return;
					root.querySelectorAll('[data-wizard-footer-step]').forEach(function(item) {
						if (item.parentElement !== footer) item.remove();
					});
					var key = root.id || 'wizard-footer';
					if (_wizardFooterTimers[key]) window.clearTimeout(_wizardFooterTimers[key]);
					footer.dataset.switching = immediate ? 'false' : 'true';
					function applyFooterStep() {
						var seen = {};
						Array.prototype.slice.call(footer.children).reverse().forEach(function(item) {
							if (!item || !item.hasAttribute || !item.hasAttribute('data-wizard-footer-step')) return;
							var itemStep = item.dataset.wizardFooterStep;
							if (seen[itemStep]) {
								item.remove();
								return;
							}
							seen[itemStep] = true;
							var active = +itemStep === +step;
							item.dataset.active = String(active);
							item.classList.toggle('hidden', !active);
						});
						footer.dataset.switching = 'false';
					}
					if (immediate) {
						applyFooterStep();
						return;
					}
					_wizardFooterTimers[key] = window.setTimeout(applyFooterStep, 180);
				}
				function wizardGo(step, immediate) {
					_wizStep = step;
					var track = document.getElementById('wizard-track');
					var root = document.getElementById('add-account-dialog');
					if (!track || !root) return;
					if (step < 0) step = 0;
					if (step > 3) step = 3;
					if (step === 3) {
						var contactStep = root.querySelector('[data-account-wizard-step="3"]');
						if (contactStep) contactStep.disabled = !addContactsEnabled();
					}
					track.style.transform = 'translateX(-' + (step * 25) + '%)';
					root.querySelectorAll('[data-account-wizard-step]').forEach(function(item) {
						item.dataset.active = String(+item.dataset.accountWizardStep === step);
					});
					root.querySelectorAll('[data-wizard-section-steps]').forEach(function(section) {
						var steps = (section.dataset.wizardSectionSteps || '').split(',');
						section.dataset.active = String(steps.indexOf(String(step)) !== -1);
					});
					setWizardFooter(root, step, !!immediate);
				}
				function addContactsEnabled() {
					var toggle = document.querySelector('[data-add-contact-sync-switch]');
					return !toggle || toggle.checked;
				}
				function syncAddContactStep() {
					var step = document.querySelector('#add-account-dialog [data-account-wizard-step="3"]');
					var content = document.getElementById('add-step-3-content');
					var ready = !!(content && content.children.length);
					if (step) step.disabled = !ready || !addContactsEnabled();
				}
				function maybeGoAddContacts() {
					if (addContactsEnabled()) {
						wizardGo(3);
					} else {
						window.location.href = '/settings/accounts';
					}
				}
				function syncWizardServiceContent(root) {
					root = root || document;
					root.querySelectorAll('[data-wizard-service-content]').forEach(function(content) {
						var service = content.dataset.wizardServiceContent;
						var toggle = root.querySelector('[data-wizard-service-switch="' + service + '"]');
						var enabled = !toggle || toggle.checked;
						content.classList.toggle('opacity-50', !enabled);
						content.classList.toggle('pointer-events-none', !enabled);
						content.classList.toggle('select-none', !enabled);
						content.setAttribute('aria-disabled', String(!enabled));
						content.querySelectorAll('input, select, textarea, button').forEach(function(el) {
							if (!el.hasAttribute('data-wizard-original-tabindex')) el.setAttribute('data-wizard-original-tabindex', el.getAttribute('tabindex') || '');
							if (enabled) {
								var original = el.getAttribute('data-wizard-original-tabindex');
								if (original === '') el.removeAttribute('tabindex'); else el.setAttribute('tabindex', original);
							} else {
								el.setAttribute('tabindex', '-1');
							}
						});
					});
				}
				document.addEventListener('click', function(event) {
					var button = event.target && event.target.closest ? event.target.closest('[data-account-wizard-action]') : null;
					if (!button) return;
					var step = Number(button.dataset.accountWizardTargetStep || 0);
					if (button.dataset.accountWizardAction === 'wizardGo') wizardGo(step);
					if (button.dataset.accountWizardAction === 'editWizardGo' && typeof editWizardGo === 'function') editWizardGo(step);
				});
				document.addEventListener('change', function(event) {
					if (event.target && event.target.matches && event.target.matches('[data-add-contact-sync-switch]')) syncAddContactStep();
					if (event.target && event.target.matches && event.target.matches('[data-wizard-service-switch]')) {
						var root = event.target.closest('#add-account-dialog,#edit-account-dialog') || document;
						syncWizardServiceContent(root);
					}
				});
				function toggleSmtpAuth(checked) {
					var fields = document.getElementById('smtp-auth-fields');
					var inputs = fields.querySelectorAll('input');
					fields.classList.toggle('opacity-50', checked);
					inputs.forEach(function(inp) { inp.disabled = checked; });
					if (checked) {
						var u = document.querySelector('input[name="username"]');
						var p = document.querySelector('input[name="password"]');
						var su = document.querySelector('input[name="smtp_username"]');
						var sp = document.querySelector('input[name="smtp_password"]');
						if (su && u) su.value = u.value;
						if (sp && p) sp.value = p.value;
					}
				}
				function contactSyncSaveButtons(accountID) {
					return document.querySelectorAll('[data-contact-sync-save-button][data-account-id="' + accountID + '"]');
				}
				function contactSyncSetSaveButton(accountID, label, disabled, continueMode) {
					contactSyncSaveButtons(accountID).forEach(function(button) {
						button.textContent = label;
						button.disabled = !!disabled;
						if (continueMode) {
							button.type = 'button';
							button.removeAttribute('form');
							button.onclick = function() { document.getElementById('edit-account-form').requestSubmit(); };
						} else {
							button.type = 'submit';
							button.setAttribute('form', 'account-contact-sync-form-' + accountID);
							button.onclick = null;
						}
					});
				}
				function contactSyncSaving(accountID) {
					contactSyncSetSaveButton(accountID, 'Saving...', true, false);
				}
				function contactSyncSaved(accountID, ok) {
					if (!ok) {
						contactSyncSetSaveButton(accountID, 'Save', false, false);
						return;
					}
					contactSyncSetSaveButton(accountID, 'Success', true, false);
					window.setTimeout(function() {
						contactSyncSetSaveButton(accountID, 'Continue', false, true);
					}, 2500);
				}
				function contactSyncResetSave(accountID) {
					contactSyncSetSaveButton(accountID, 'Save', false, false);
				}
				function toggleCardDAVAuth(checkbox) {
					var form = checkbox && checkbox.closest ? checkbox.closest('form') : null;
					if (!form) return;
					var fields = form.querySelector('[data-carddav-credential-fields]');
					if (!fields) return;
					fields.classList.toggle('opacity-50', checkbox.checked);
					fields.querySelectorAll('input[name="username"], input[name="password"]').forEach(function(input) {
						input.disabled = checkbox.checked;
					});
				}
				function discoverCardDAV(accountID, fieldsID, statusID, autodiscover) {
					var fields = document.getElementById(fieldsID);
					var status = document.getElementById(statusID);
					if (!fields || !status) return;
					var controller = window.AbortController ? new AbortController() : null;
					var timeout = controller ? window.setTimeout(function() { controller.abort(); }, 28000) : null;
					var body = new URLSearchParams();
					fields.querySelectorAll('input, select, textarea').forEach(function(input) {
						if (!input.name || input.disabled) return;
						body.append(input.name, input.value || '');
					});
					if (autodiscover) body.append('autodiscover', '1');
					function renderDiscoveryProgress(completed, total, endpoint) {
						var percent = total > 0 ? Math.max(0, Math.min(100, Math.round((completed / total) * 100))) : 0;
						var label = total > 0 ? 'Testing ' + Math.min(completed + 1, total) + ' of ' + total + ' CardDAV checks' : 'Preparing CardDAV discovery...';
						var safeEndpoint = endpoint ? endpoint.replace(/[&<>"]/g, function(ch) { return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[ch]); }) : '';
						status.innerHTML = '<div class="rounded-lg border border-border bg-background/60 p-3 text-xs text-muted-foreground"><div class="flex items-center justify-between gap-3"><span class="font-medium text-foreground">' + label + '</span><span class="tabular-nums">' + completed + '/' + (total || '?') + '</span></div><div class="mt-2 h-1.5 overflow-hidden rounded-md bg-muted"><div class="h-full rounded-md bg-primary transition-all" style="width:' + percent + '%"></div></div>' + (safeEndpoint ? '<div class="mt-2 truncate">' + safeEndpoint + '</div>' : '') + '</div>';
					}
					renderDiscoveryProgress(0, 0, '');
					fetch('/api/accounts/' + encodeURIComponent(accountID) + '/contacts/sync/discover', {
						method: 'POST',
						credentials: 'same-origin',
						headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/x-ndjson' },
						body: body.toString(),
						signal: controller ? controller.signal : undefined
					}).then(function(resp) {
						if (!resp.body || !resp.body.getReader) throw new Error('stream unavailable');
						var reader = resp.body.getReader();
						var decoder = new TextDecoder();
						var buffer = '';
						function handleEvent(event) {
							if (!event || !event.type) return;
							if (event.type === 'progress') {
								renderDiscoveryProgress(event.completed || 0, event.total || 0, event.endpoint || '');
								return;
							}
							if (event.type === 'error') {
								if (timeout) window.clearTimeout(timeout);
								var err = document.createElement('div');
								err.className = 'rounded-md border border-destructive/20 bg-destructive/10 px-3 py-2 text-xs text-destructive';
								err.textContent = event.error || 'Could not discover CardDAV address books.';
								status.textContent = '';
								status.appendChild(err);
								return;
							}
							if (event.type === 'done') {
								if (timeout) window.clearTimeout(timeout);
								renderDiscoveryResults(event.address_books || []);
							}
						}
						function read() {
							return reader.read().then(function(result) {
								if (result.done) return;
								buffer += decoder.decode(result.value, { stream: true });
								var lines = buffer.split('\n');
								buffer = lines.pop() || '';
								lines.forEach(function(line) {
									line = line.trim();
									if (!line) return;
									try { handleEvent(JSON.parse(line)); } catch (_) {}
								});
								return read();
							});
						}
						return read();
					}).catch(function(err) {
						if (timeout) window.clearTimeout(timeout);
						var message = err && err.name === 'AbortError' ? 'CardDAV discovery timed out. Check the app logs for the attempted DNS and URL checks, or enter the provider\'s exact CardDAV base URL and try again.' : 'Could not discover CardDAV address books. Check the app logs for details.';
						status.innerHTML = '<div class="rounded-md border border-destructive/20 bg-destructive/10 px-3 py-2 text-xs text-destructive">' + message + '</div>';
					});
					function renderDiscoveryResults(books) {
						status.textContent = '';
						if (!books.length) {
							var empty = document.createElement('div');
							empty.className = 'rounded-md border border-border bg-background/60 px-3 py-2 text-xs text-muted-foreground';
							empty.textContent = 'No CardDAV address books were found.';
							status.appendChild(empty);
							return;
						}
						var pickerSection = fields.querySelector('[data-carddav-addressbook-section]');
						if (pickerSection) pickerSection.classList.remove('hidden');
						var existingInputs = fields.querySelectorAll('input[name="addressbook_url"]');
						var selected = {};
						existingInputs.forEach(function(input) { if (input.value) selected[input.value] = true; });
						var wrap = document.createElement('div');
						wrap.className = pickerSection ? '' : 'rounded-lg border border-border bg-background/60 p-3';
						var title = document.createElement('div');
						title.className = 'text-xs font-semibold text-foreground';
						title.textContent = 'Choose address books';
						wrap.appendChild(title);
						var hint = document.createElement('p');
						hint.className = 'mt-1 text-[11px] leading-relaxed text-muted-foreground';
						hint.textContent = 'Select one or more address books to sync. The default is used for new contacts.';
						wrap.appendChild(hint);
						var list = document.createElement('div');
						list.className = 'mt-3 space-y-2';
						books.forEach(function(book) {
							var row = document.createElement('label');
							row.className = 'flex w-full items-start gap-3 rounded-md border border-border bg-card px-3 py-2 text-xs transition-colors hover:bg-accent';
							var checkWrap = document.createElement('div');
							checkWrap.className = 'relative mt-0.5 inline-flex items-center';
							var check = document.createElement('input');
							check.type = 'checkbox';
							check.name = 'addressbook_url';
							check.value = book.url || '';
							check.checked = !!selected[book.url] || Object.keys(selected).length === 0;
							check.className = 'peer size-4 shrink-0 rounded-sm border border-input shadow-xs focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 focus-visible:border-ring disabled:cursor-not-allowed disabled:opacity-50 checked:bg-primary checked:text-primary-foreground checked:border-primary indeterminate:bg-primary indeterminate:text-primary-foreground indeterminate:border-primary appearance-none cursor-pointer transition-shadow relative';
							var checkIcon = document.createElement('div');
							checkIcon.className = 'absolute inset-0 pointer-events-none flex items-center justify-center text-primary-foreground opacity-0 peer-checked:opacity-100';
							checkIcon.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5" data-lucide="icon"><path d="M20 6 9 17l-5-5"></path></svg>';
							checkWrap.appendChild(check);
							checkWrap.appendChild(checkIcon);
							var hiddenName = document.createElement('input');
							hiddenName.type = 'hidden';
							hiddenName.name = 'addressbook_name';
							hiddenName.value = book.name || '';
							hiddenName.disabled = !check.checked;
							var hiddenID = document.createElement('input');
							hiddenID.type = 'hidden';
							hiddenID.name = 'addressbook_id';
							hiddenID.value = book.id || '';
							hiddenID.disabled = !check.checked;
							var content = document.createElement('div');
							content.className = 'min-w-0 flex-1';
							var name = document.createElement('div');
							name.className = 'font-semibold text-foreground';
							name.textContent = book.name || 'Address book';
							var url = document.createElement('div');
							url.className = 'mt-0.5 truncate text-muted-foreground';
							url.textContent = book.url || '';
							var defaultWrap = document.createElement('label');
							defaultWrap.className = 'mt-2 inline-flex items-center gap-1.5 text-[11px] text-muted-foreground';
							var radio = document.createElement('input');
							radio.type = 'radio';
							radio.name = 'default_addressbook_url';
							radio.value = book.url || '';
							radio.disabled = !check.checked;
							radio.className = 'relative h-4 w-4 before:absolute before:left-1/2 before:top-1/2 before:h-1.5 before:w-1.5 before:-translate-x-1/2 before:-translate-y-1/2 appearance-none rounded-full border-2 border-primary before:content-[\'\'] before:rounded-full before:bg-background checked:border-primary checked:bg-primary checked:before:visible focus-visible:outline-hidden focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background disabled:cursor-not-allowed';
							defaultWrap.appendChild(radio);
							defaultWrap.appendChild(document.createTextNode('Default for new contacts'));
							content.appendChild(name);
							content.appendChild(url);
							content.appendChild(defaultWrap);
							row.appendChild(checkWrap);
							row.appendChild(hiddenID);
							row.appendChild(hiddenName);
							row.appendChild(content);
							check.addEventListener('change', function() {
								radio.disabled = !check.checked;
								hiddenName.disabled = !check.checked;
								hiddenID.disabled = !check.checked;
								row.classList.toggle('border-primary', check.checked);
								row.classList.toggle('bg-primary/10', check.checked);
								if (check.checked && !list.querySelector('input[name="default_addressbook_url"]:checked')) radio.checked = true;
								if (!check.checked && radio.checked) {
									radio.checked = false;
									var next = list.querySelector('input[name="addressbook_url"]:checked');
									if (next) next.closest('label').querySelector('input[name="default_addressbook_url"]').checked = true;
								}
							});
							if (check.checked) row.classList.add('border-primary', 'bg-primary/10');
							list.appendChild(row);
						});
						var firstChecked = list.querySelector('input[name="addressbook_url"]:checked');
						if (firstChecked) firstChecked.closest('label').querySelector('input[name="default_addressbook_url"]').checked = true;
						wrap.appendChild(list);
						if (pickerSection) {
							pickerSection.textContent = '';
							pickerSection.appendChild(wrap);
						} else {
							status.appendChild(wrap);
						}
					}
				}
				document.addEventListener('click', function(event) {
					var button = event.target && event.target.closest ? event.target.closest('[data-carddav-discover]') : null;
					if (!button) return;
					event.preventDefault();
					discoverCardDAV(button.dataset.accountId || '', button.dataset.fieldsId || '', button.dataset.statusId || '', button.dataset.carddavAutodiscover === 'true');
				});
				document.addEventListener('click', function(event) {
					var button = event.target && event.target.closest ? event.target.closest('[data-carddav-manual]') : null;
					if (!button) return;
					event.preventDefault();
					var fields = document.getElementById(button.dataset.fieldsId || '');
					if (!fields) return;
					var manual = fields.querySelector('[data-carddav-manual-addressbook]');
					if (!manual) return;
					manual.classList.remove('hidden');
					var input = manual.querySelector('input[name="addressbook_url"]');
					if (input) input.focus();
				});
				document.addEventListener('input', function(event) {
					var form = event.target && event.target.closest ? event.target.closest('[data-contact-sync-form]') : null;
					if (form) contactSyncResetSave(form.dataset.accountId || '');
				});
				document.addEventListener('change', function(event) {
					var form = event.target && event.target.closest ? event.target.closest('[data-contact-sync-form]') : null;
					if (form) contactSyncResetSave(form.dataset.accountId || '');
				});
				document.body.addEventListener('htmx:beforeRequest', function(event) {
					var form = event.target && event.target.closest ? event.target.closest('[data-contact-sync-form]') : null;
					if (form) contactSyncSaving(form.dataset.accountId || '');
				});
				document.body.addEventListener('htmx:afterRequest', function(event) {
					var form = event.target && event.target.closest ? event.target.closest('[data-contact-sync-form]') : null;
					if (!form) return;
					var xhr = event.detail && event.detail.xhr ? event.detail.xhr : null;
					var ok = !!(event.detail && event.detail.successful) && (!xhr || xhr.getResponseHeader('X-Gofer-Status') !== 'error');
					contactSyncSaved(form.dataset.accountId || '', ok);
				});
				function refreshCardDAVBaseURLActions(root) {
					(root || document).querySelectorAll('[data-carddav-base-url-action]').forEach(function(group) {
						var fields = document.getElementById(group.dataset.fieldsId || '');
						var base = fields && fields.querySelector ? fields.querySelector('input[name="base_url"]') : null;
						var enabled = !!(base && base.value && base.value.trim());
						var enabledAction = group.querySelector('[data-carddav-enabled-action]');
						var disabledAction = group.querySelector('[data-carddav-disabled-action]');
						if (enabledAction) enabledAction.classList.toggle('!hidden', !enabled);
						if (disabledAction) disabledAction.classList.toggle('!hidden', enabled);
					});
				}
				document.addEventListener('input', function(event) {
					if (!event.target || !event.target.matches || !event.target.matches('input[name="base_url"]')) return;
					refreshCardDAVBaseURLActions(document);
				});
				document.addEventListener('DOMContentLoaded', function() { refreshCardDAVBaseURLActions(document); });
				document.body.addEventListener('htmx:afterSwap', function(event) {
					refreshCardDAVBaseURLActions(event.target || document);
					var addRoot = document.getElementById('add-account-dialog');
					if (addRoot && typeof _wizStep !== 'undefined') setWizardFooter(addRoot, _wizStep, true);
					if (addRoot) syncWizardServiceContent(addRoot);
					var editRoot = document.getElementById('edit-account-dialog');
					if (editRoot && typeof _editWizStep !== 'undefined') setWizardFooter(editRoot, _editWizStep, true);
					if (editRoot) syncWizardServiceContent(editRoot);
				});
				document.body.addEventListener('htmx:oobAfterSwap', function() {
					var addRoot = document.getElementById('add-account-dialog');
					if (addRoot && typeof _wizStep !== 'undefined') setWizardFooter(addRoot, _wizStep, true);
					if (addRoot) syncWizardServiceContent(addRoot);
					var editRoot = document.getElementById('edit-account-dialog');
					if (editRoot && typeof _editWizStep !== 'undefined') setWizardFooter(editRoot, _editWizStep, true);
					if (editRoot) syncWizardServiceContent(editRoot);
				});
				document.body.addEventListener('htmx:afterSettle', function() {
					var addRoot = document.getElementById('add-account-dialog');
					if (addRoot && typeof _wizStep !== 'undefined') setWizardFooter(addRoot, _wizStep, true);
					if (addRoot) syncWizardServiceContent(addRoot);
					var editRoot = document.getElementById('edit-account-dialog');
					if (editRoot && typeof _editWizStep !== 'undefined') setWizardFooter(editRoot, _editWizStep, true);
					if (editRoot) syncWizardServiceContent(editRoot);
				});
				document.addEventListener('DOMContentLoaded', function() {
					var dlg = document.querySelector('#add-account-dialog dialog[data-tui-dialog-content]');
					if (!dlg) return;
					new MutationObserver(function() {
						var track = document.getElementById('wizard-track');
						if (!track) return;
						if (dlg.open) {
							wizardGo(0, true);
							syncAddContactStep();
							syncWizardServiceContent(document.getElementById('add-account-dialog'));
						}
					}).observe(dlg, { attributes: true, attributeFilter: ['open'] });
				});
			</script>
			<div class="account-wizard-shell grid gap-4 pt-2 md:grid-cols-[14.5rem_minmax(0,1fr)]">
		@AccountWizardAddSidebar()
				<div id="wizard-viewport" class="account-wizard-viewport">
					<div id="wizard-track" class="flex items-start transition-transform duration-300 ease-in-out" style="width: 400%">
						<form id="account-form" hx-post="/api/accounts" hx-target="#add-step-3-content" hx-swap="innerHTML" class="contents">
						<div class="w-1/4 shrink-0 px-1" data-wizard-step="0">
							<div class="account-wizard-panel">
							<div class="account-wizard-scroll" data-wizard-service-content="email">
							<h4 class="account-wizard-sticky-header text-sm font-semibold text-foreground flex items-center gap-2">
								@icon.User(icon.Props{Class: "size-4 text-muted-foreground"})
								Account details
							</h4>
							<div class="space-y-4">
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Email Address</label>
									@input.Input(input.Props{
										Name:        "email_address",
										Type:        input.TypeEmail,
										Placeholder: "you@example.com",
										Required:    true,
									})
								</div>
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Display Name</label>
									@input.Input(input.Props{
										Name:        "display_name",
										Type:        input.TypeText,
										Placeholder: "Your Name",
									})
								</div>
							</div>
							</div>
							<div class="account-wizard-controls flex justify-end">
								<button type="button" onclick="wizardGo(1)" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
									Next
									@icon.ChevronRight(icon.Props{Class: "size-4"})
								</button>
							</div>
							</div>
						</div>

						<div class="w-1/4 shrink-0 px-1" data-wizard-step="1">
							<div class="account-wizard-panel">
							<div class="account-wizard-scroll" data-wizard-service-content="email">
							<h4 class="account-wizard-sticky-header text-sm font-semibold text-foreground flex items-center gap-2">
								@icon.Inbox(icon.Props{Class: "size-4 text-muted-foreground"})
								Incoming Mail
								<span class="text-xs font-normal text-muted-foreground">(IMAP)</span>
							</h4>
							<div class="grid grid-cols-2 gap-3">
								<div class="col-span-2">
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">IMAP Host</label>
									@input.Input(input.Props{
										Name:        "imap_host",
										Type:        input.TypeText,
										Placeholder: "imap.example.com",
										Required:    true,
									})
								</div>
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Port</label>
									@input.Input(input.Props{
										Name:        "imap_port",
										Type:        input.TypeNumber,
										Placeholder: "993",
										Value:       "993",
									})
								</div>
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Encryption</label>
									@selectbox.SelectBox() {
									@selectbox.Trigger(selectbox.TriggerProps{Name: "imap_tls_mode", DisableClear: true}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "TLS"}) { TLS }
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Item(selectbox.ItemProps{Value: "tls", Selected: true}) { TLS }
											@selectbox.Item(selectbox.ItemProps{Value: "starttls"}) { STARTTLS }
											@selectbox.Item(selectbox.ItemProps{Value: "none"}) { None }
										}
									}
								</div>
							</div>
							<hr class="my-4 border-border"/>
							<h4 class="text-sm font-semibold text-foreground flex items-center gap-2 mb-4">
								@icon.Key(icon.Props{Class: "size-4 text-muted-foreground"})
								Login
							</h4>
							<div class="grid grid-cols-2 gap-3">
								<div class="col-span-2">
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Username</label>
									@input.Input(input.Props{
										Name:        "username",
										Type:        input.TypeText,
										Placeholder: "you@example.com",
										Required:    true,
									})
								</div>
								<div class="col-span-2">
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Password</label>
									@input.Input(input.Props{
										Name:        "password",
										Type:        input.TypePassword,
										Placeholder: "••••••••",
										Required:    true,
									})
								</div>
								<div class="col-span-2">
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Method</label>
									@selectbox.SelectBox() {
										@selectbox.Trigger(selectbox.TriggerProps{Name: "auth_method"}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "PLAIN"}) { PLAIN }
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Item(selectbox.ItemProps{Value: "plain", Selected: true}) { PLAIN }
										}
									}
								</div>
							</div>
							</div>
							<div class="account-wizard-controls flex justify-between">
								<button type="button" onclick="wizardGo(0)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
									@icon.ArrowLeft(icon.Props{Class: "size-4"})
									Back
								</button>
								<button type="button" onclick="wizardGo(2)" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
									Next
									@icon.ChevronRight(icon.Props{Class: "size-4"})
								</button>
							</div>
							</div>
						</div>

						<div class="w-1/4 shrink-0 px-1" data-wizard-step="2">
							<div class="account-wizard-panel">
							<div class="account-wizard-scroll" data-wizard-service-content="email">
							<h4 class="account-wizard-sticky-header text-sm font-semibold text-foreground flex items-center gap-2">
								@icon.Send(icon.Props{Class: "size-4 text-muted-foreground"})
								Sending Mail
								<span class="text-xs font-normal text-muted-foreground">(SMTP)</span>
							</h4>
							<div class="grid grid-cols-2 gap-3">
								<div class="col-span-2">
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">SMTP Host</label>
									@input.Input(input.Props{
										Name:        "smtp_host",
										Type:        input.TypeText,
										Placeholder: "smtp.example.com",
										Required:    true,
									})
								</div>
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Port</label>
									@input.Input(input.Props{
										Name:        "smtp_port",
										Type:        input.TypeNumber,
										Placeholder: "465",
										Value:       "465",
									})
								</div>
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Encryption</label>
									@selectbox.SelectBox() {
									@selectbox.Trigger(selectbox.TriggerProps{Name: "smtp_tls_mode", DisableClear: true}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "TLS"}) { TLS }
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Item(selectbox.ItemProps{Value: "tls", Selected: true}) { TLS }
											@selectbox.Item(selectbox.ItemProps{Value: "starttls"}) { STARTTLS }
											@selectbox.Item(selectbox.ItemProps{Value: "none"}) { None }
										}
									}
								</div>
							</div>
							<hr class="my-4 border-border"/>
							<label class="flex items-center gap-2 cursor-pointer mb-4">
								@checkbox.Checkbox(checkbox.Props{
									ID:         "smtp-same-auth",
									Checked:    true,
									Attributes: templ.Attributes{"onchange": "toggleSmtpAuth(this.checked)"},
								})
								<span class="text-sm">Use same login as incoming mail</span>
							</label>
							<div id="smtp-auth-fields" class="opacity-50">
								<div class="grid grid-cols-2 gap-3">
									<div class="col-span-2">
										<label class="text-xs font-medium text-muted-foreground mb-1.5 block">SMTP Username</label>
										@input.Input(input.Props{
											Name:        "smtp_username",
											Type:        input.TypeText,
											Placeholder: "you@example.com",
											Disabled:    true,
										})
									</div>
									<div class="col-span-2">
										<label class="text-xs font-medium text-muted-foreground mb-1.5 block">SMTP Password</label>
										@input.Input(input.Props{
											Name:        "smtp_password",
											Type:        input.TypePassword,
											Placeholder: "••••••••",
											Disabled:    true,
										})
									</div>
								</div>
							</div>
							</div>
							<div class="account-wizard-controls flex justify-between">
								<button type="button" onclick="wizardGo(1)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
									@icon.ArrowLeft(icon.Props{Class: "size-4"})
									Back
								</button>
								<button type="submit" class="btn-skeuo inline-flex items-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-lg">
									@icon.Plus(icon.Props{Class: "size-4"})
									Add Account
								</button>
							</div>
							</div>
						</div>
						</form>

						<div class="w-1/4 shrink-0 px-1" data-wizard-step="3">
							<div class="account-wizard-panel">
								<div id="add-step-3-content" data-wizard-service-content="contacts" hx-on::after-swap="syncAddContactStep(); maybeGoAddContacts()"></div>
							</div>
						</div>
					</div>
					</div>
				</div>
				@AddAccountWizardFooter()
			}
		}
}

templ AccountWizardAddSidebar() {
	<aside class="rounded-lg border border-border bg-muted/25 p-2 md:min-h-[28rem]">
		<div class="mb-2 px-2">
			<div class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">Setup sections</div>
			<p class="mt-0.5 text-[11px] leading-snug text-muted-foreground/80">Enable/disable the services you need</p>
		</div>
		@AccountWizardEmailSection("wizardGo", "", true, true, false)
		@AccountWizardTopStep("wizardGo", 3, "2", "Contacts", "Optional sync", true, true, "", "contacts", true, false, templ.Attributes{"data-add-contact-sync-switch": ""})
	</aside>
}

templ AccountWizardEditSidebar(data models.EditAccountData) {
	<aside class="rounded-lg border border-border bg-muted/25 p-2 md:min-h-[28rem]">
		<div class="mb-2 px-2">
			<div class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">Settings sections</div>
			<p class="mt-0.5 text-[11px] leading-snug text-muted-foreground/80">Enable/disable the services you need</p>
		</div>
		@AccountWizardEmailSection("editWizardGo", data.AccountID, data.EmailSyncEnabled, false, true)
		@AccountWizardTopStep("editWizardGo", 3, "2", "Contacts", "Optional sync", false, true, data.AccountID, "contacts", data.ContactSync.Enabled, false, nil)
		@AccountWizardTopStep("editWizardGo", 4, "3", "Finish", "Test results", false, false, "", "", false, false, nil)
	</aside>
}

templ AccountWizardEmailSection(goFn string, accountID string, enabled bool, disabled bool, persist bool) {
	<div class="account-wizard-section" data-wizard-section-steps="0,1,2" data-active="true">
		<div class="account-wizard-section-heading">
			<button type="button" data-account-wizard-action={ goFn } data-account-wizard-target-step="0" class="account-wizard-section-title">
				<span class="account-wizard-index">1</span>
				<span class="min-w-0"><span class="block text-sm font-semibold">Email</span><span class="block text-xs text-muted-foreground">Mail account setup</span></span>
			</button>
			@AccountWizardSectionSwitch(accountID, "email", enabled, disabled, persist, nil)
		</div>
		<div class="account-wizard-substeps">
			@AccountWizardSubStep(goFn, 0, "1.a", "Account details", "Name and email", false, true)
			@AccountWizardSubStep(goFn, 1, "1.b", "Incoming", "IMAP settings", false, false)
			@AccountWizardSubStep(goFn, 2, "1.c", "Outgoing", "SMTP settings", false, false)
		</div>
	</div>
}

templ AccountWizardSubStep(goFn string, step int, index string, title string, description string, disabled bool, active bool) {
	<button type="button" data-account-wizard-action={ goFn } data-account-wizard-target-step={ strconv.Itoa(step) } class="account-wizard-step" data-account-wizard-step={ strconv.Itoa(step) } data-active={ strconv.FormatBool(active) } disabled?={ disabled }>
		<span class="account-wizard-index">{ index }</span>
		<span class="min-w-0"><span class="block text-xs font-semibold">{ title }</span><span class="block text-[11px] text-muted-foreground">{ description }</span></span>
	</button>
}

templ AccountWizardTopStep(goFn string, step int, index string, title string, description string, disabled bool, section bool, accountID string, service string, enabled bool, switchDisabled bool, attrs templ.Attributes) {
	<div class="account-wizard-section" data-wizard-section-steps={ strconv.Itoa(step) } data-active="false">
		<div class="account-wizard-section-heading">
			<button type="button" data-account-wizard-action={ goFn } data-account-wizard-target-step={ strconv.Itoa(step) } class="account-wizard-section-title" data-account-wizard-step={ strconv.Itoa(step) } data-active="false" disabled?={ disabled }>
				<span class="account-wizard-index">{ index }</span>
				<span class="min-w-0"><span class="block text-sm font-semibold">{ title }</span><span class="block text-xs text-muted-foreground">{ description }</span></span>
			</button>
			if service != "" {
				@AccountWizardSectionSwitch(accountID, service, enabled, switchDisabled, accountID != "", attrs)
			}
		</div>
	</div>
}

templ AccountWizardSectionSwitch(accountID string, service string, enabled bool, disabled bool, persist bool, attrs templ.Attributes) {
	<form
		class="shrink-0 pt-0.5"
		if persist {
			hx-post={ fmt.Sprintf("/api/accounts/%s/services", accountID) }
			hx-swap="none"
		}
	>
		if persist {
			<input type="hidden" name="service" value={ service }/>
		}
		@switchcomp.Switch(switchcomp.Props{
			ID:         fmt.Sprintf("account-wizard-%s-%s", accountID, service),
			Name:       "enabled",
			Value:      "true",
			Checked:    enabled,
			Disabled:   disabled,
			Attributes: mergeTemplAttrs(attrs, templ.Attributes{"data-wizard-service-switch": service, "onchange": "if (this.form.hasAttribute('hx-post')) this.form.requestSubmit()"}),
		})
	</form>
}

func mergeTemplAttrs(base templ.Attributes, extra templ.Attributes) templ.Attributes {
	if base == nil {
		base = templ.Attributes{}
	}
	for k, v := range extra {
		base[k] = v
	}
	return base
}

templ AddAccountWizardFooter() {
	<div id="add-wizard-footer" class="account-wizard-card-footer">
		<div data-wizard-footer-step="0" data-active="true" class="flex justify-end">
			<button type="button" onclick="wizardGo(1)" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
				Next
				@icon.ChevronRight(icon.Props{Class: "size-4"})
			</button>
		</div>
		<div data-wizard-footer-step="1" data-active="false" class="hidden flex justify-between">
			<button type="button" onclick="wizardGo(0)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
				@icon.ArrowLeft(icon.Props{Class: "size-4"})
				Back
			</button>
			<button type="button" onclick="wizardGo(2)" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
				Next
				@icon.ChevronRight(icon.Props{Class: "size-4"})
			</button>
		</div>
		<div data-wizard-footer-step="2" data-active="false" class="hidden flex justify-between">
			<button type="button" onclick="wizardGo(1)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
				@icon.ArrowLeft(icon.Props{Class: "size-4"})
				Back
			</button>
			<button type="submit" form="account-form" class="btn-skeuo inline-flex items-center gap-1.5 text-sm font-semibold px-4 py-2 rounded-lg">
				@icon.Plus(icon.Props{Class: "size-4"})
				Add Account
			</button>
		</div>
		<div id="add-wizard-footer-step-3" data-wizard-footer-step="3" data-active="false" class="hidden"></div>
	</div>
}

templ EditAccountDialog(data models.EditAccountData) {
	@dialog.Dialog(dialog.Props{ID: "edit-account-dialog"}) {
		@dialog.Content(dialog.ContentProps{Class: "account-wizard-dialog sm:max-w-4xl"}) {
			@dialog.Header() {
				@dialog.Title() {
					Edit Account
				}
				@dialog.Description() {
					Update mail settings and optional contact sync.
				}
			}
			<script>
				var _editWizStep = 0;
				function editWizardGo(step, immediate) {
					_editWizStep = step;
					var track = document.getElementById('edit-wizard-track');
					var root = document.getElementById('edit-account-dialog');
					if (!track || !root) return;
					if (step < 0) step = 0;
					if (step > 4) step = 4;
					track.style.transform = 'translateX(-' + (step * 20) + '%)';
					root.querySelectorAll('[data-account-wizard-step]').forEach(function(item) {
						item.dataset.active = String(+item.dataset.accountWizardStep === step);
					});
					root.querySelectorAll('[data-wizard-section-steps]').forEach(function(section) {
						var steps = (section.dataset.wizardSectionSteps || '').split(',');
						section.dataset.active = String(steps.indexOf(String(step)) !== -1);
					});
					setWizardFooter(root, step, !!immediate);
				}
				function editToggleSmtpAuth(checked) {
					var fields = document.getElementById('edit-smtp-auth-fields');
					var inputs = fields.querySelectorAll('input');
					fields.classList.toggle('opacity-50', checked);
					inputs.forEach(function(inp) { inp.disabled = checked; });
					if (checked) {
						var form = document.getElementById('edit-account-form');
						var u = form.querySelector('input[name="username"]');
						var p = form.querySelector('input[name="password"]');
						var su = form.querySelector('input[name="smtp_username"]');
						var sp = form.querySelector('input[name="smtp_password"]');
						if (su && u) su.value = u.value;
						if (sp && p) sp.value = p.value;
					}
				}
			</script>
			<div class="account-wizard-shell grid gap-4 pt-2 md:grid-cols-[14.5rem_minmax(0,1fr)]">
		@AccountWizardEditSidebar(data)
				<div id="edit-wizard-viewport" class="account-wizard-viewport">
					<div id="edit-wizard-track" class="flex items-start transition-transform duration-300 ease-in-out" style="width: 500%">
						<form id="edit-account-form" hx-post={ fmt.Sprintf("/api/accounts/%s/edit", data.AccountID) } hx-target="#edit-step-4-content" hx-swap="innerHTML" hx-on::after-request="editWizardGo(4)" class="contents">
						<div class="w-1/5 shrink-0 px-1" data-wizard-step="0">
							<div class="account-wizard-panel">
							<div class="account-wizard-scroll" data-wizard-service-content="email">
							<h4 class="account-wizard-sticky-header text-sm font-semibold text-foreground flex items-center gap-2">
								@icon.User(icon.Props{Class: "size-4 text-muted-foreground"})
								Account details
							</h4>
							<div class="space-y-4">
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Email Address</label>
									@input.Input(input.Props{
										Name:  "email_address",
										Type:  input.TypeEmail,
										Value: data.EmailAddress,
									})
								</div>
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Display Name</label>
									@input.Input(input.Props{
										Name:  "display_name",
										Type:  input.TypeText,
										Value: data.DisplayName,
									})
								</div>
							</div>
							</div>
							<div class="account-wizard-controls flex justify-end">
								<button type="button" onclick="editWizardGo(1)" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
									Next
									@icon.ChevronRight(icon.Props{Class: "size-4"})
								</button>
							</div>
							</div>
						</div>

						<div class="w-1/5 shrink-0 px-1" data-wizard-step="1">
							<div class="account-wizard-panel">
							<div class="account-wizard-scroll" data-wizard-service-content="email">
							<h4 class="account-wizard-sticky-header text-sm font-semibold text-foreground flex items-center gap-2">
								@icon.Inbox(icon.Props{Class: "size-4 text-muted-foreground"})
								Incoming Mail
								<span class="text-xs font-normal text-muted-foreground">(IMAP)</span>
							</h4>
							<div class="grid grid-cols-2 gap-3">
								<div class="col-span-2">
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">IMAP Host</label>
									@input.Input(input.Props{
										Name:  "imap_host",
										Type:  input.TypeText,
										Value: data.IMAPHost,
									})
								</div>
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Port</label>
									@input.Input(input.Props{
										Name:  "imap_port",
										Type:  input.TypeNumber,
										Value: strconv.Itoa(data.IMAPPort),
									})
								</div>
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Encryption</label>
									@selectbox.SelectBox() {
									@selectbox.Trigger(selectbox.TriggerProps{Name: "imap_tls_mode", DisableClear: true}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "TLS"}) { TLS }
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Item(selectbox.ItemProps{Value: "tls", Selected: data.IMAPTLSMode == "tls"}) { TLS }
											@selectbox.Item(selectbox.ItemProps{Value: "starttls", Selected: data.IMAPTLSMode == "starttls"}) { STARTTLS }
											@selectbox.Item(selectbox.ItemProps{Value: "none", Selected: data.IMAPTLSMode == "none"}) { None }
										}
									}
								</div>
							</div>
							<hr class="my-4 border-border"/>
							<h4 class="text-sm font-semibold text-foreground flex items-center gap-2 mb-4">
								@icon.Key(icon.Props{Class: "size-4 text-muted-foreground"})
								Login
							</h4>
							<div class="grid grid-cols-2 gap-3">
								<div class="col-span-2">
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Username</label>
									@input.Input(input.Props{
										Name:  "username",
										Type:  input.TypeText,
										Value: data.Username,
									})
								</div>
								<div class="col-span-2">
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Password</label>
									@input.Input(input.Props{
										Name:        "password",
										Type:        input.TypePassword,
										Placeholder: "Leave blank to keep current",
									})
								</div>
								<div class="col-span-2">
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Method</label>
									@selectbox.SelectBox() {
										@selectbox.Trigger(selectbox.TriggerProps{Name: "auth_method"}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "PLAIN"}) { PLAIN }
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Item(selectbox.ItemProps{Value: "plain", Selected: data.AuthMethod == "plain"}) { PLAIN }
											@selectbox.Item(selectbox.ItemProps{Value: "oauth2", Selected: data.AuthMethod == "oauth2"}) { OAuth2 }
										}
									}
								</div>
							</div>
							</div>
							<div class="account-wizard-controls flex justify-between">
								<button type="button" onclick="editWizardGo(0)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
									@icon.ArrowLeft(icon.Props{Class: "size-4"})
									Back
								</button>
								<button type="button" onclick="editWizardGo(2)" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
									Next
									@icon.ChevronRight(icon.Props{Class: "size-4"})
								</button>
							</div>
							</div>
						</div>

						<div class="w-1/5 shrink-0 px-1" data-wizard-step="2">
							<div class="account-wizard-panel">
							<div class="account-wizard-scroll" data-wizard-service-content="email">
							<h4 class="account-wizard-sticky-header text-sm font-semibold text-foreground flex items-center gap-2">
								@icon.Send(icon.Props{Class: "size-4 text-muted-foreground"})
								Sending Mail
								<span class="text-xs font-normal text-muted-foreground">(SMTP)</span>
							</h4>
							<div class="grid grid-cols-2 gap-3">
								<div class="col-span-2">
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">SMTP Host</label>
									@input.Input(input.Props{
										Name:  "smtp_host",
										Type:  input.TypeText,
										Value: data.SMTPHost,
									})
								</div>
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Port</label>
									@input.Input(input.Props{
										Name:  "smtp_port",
										Type:  input.TypeNumber,
										Value: strconv.Itoa(data.SMTPPort),
									})
								</div>
								<div>
									<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Encryption</label>
									@selectbox.SelectBox() {
									@selectbox.Trigger(selectbox.TriggerProps{Name: "smtp_tls_mode", DisableClear: true}) {
											@selectbox.Value(selectbox.ValueProps{Placeholder: "TLS"}) { TLS }
										}
										@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
											@selectbox.Item(selectbox.ItemProps{Value: "tls", Selected: data.SMTPTLSMode == "tls"}) { TLS }
											@selectbox.Item(selectbox.ItemProps{Value: "starttls", Selected: data.SMTPTLSMode == "starttls"}) { STARTTLS }
											@selectbox.Item(selectbox.ItemProps{Value: "none", Selected: data.SMTPTLSMode == "none"}) { None }
										}
									}
								</div>
							</div>
							<hr class="my-4 border-border"/>
							<label class="flex items-center gap-2 cursor-pointer mb-4">
								@checkbox.Checkbox(checkbox.Props{
									ID:         "edit-smtp-same-auth",
									Checked:    data.SameSmtpAuth,
									Attributes: templ.Attributes{"onchange": "editToggleSmtpAuth(this.checked)"},
								})
								<span class="text-sm">Use same login as incoming mail</span>
							</label>
							<div id="edit-smtp-auth-fields" class={ templ.KV("opacity-50", data.SameSmtpAuth) }>
								<div class="grid grid-cols-2 gap-3">
									<div class="col-span-2">
										<label class="text-xs font-medium text-muted-foreground mb-1.5 block">SMTP Username</label>
										@input.Input(input.Props{
											Name:     "smtp_username",
											Type:     input.TypeText,
											Value:    data.SmtpUsername,
											Disabled: data.SameSmtpAuth,
										})
									</div>
									<div class="col-span-2">
										<label class="text-xs font-medium text-muted-foreground mb-1.5 block">SMTP Password</label>
										@input.Input(input.Props{
											Name:        "smtp_password",
											Type:        input.TypePassword,
											Placeholder: "Leave blank to keep current",
											Disabled:    data.SameSmtpAuth,
										})
									</div>
								</div>
							</div>
							</div>
							<div class="account-wizard-controls flex justify-between">
								<button type="button" onclick="editWizardGo(1)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
									@icon.ArrowLeft(icon.Props{Class: "size-4"})
									Back
								</button>
								<button type="button" onclick="editWizardGo(3)" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
									Next
									@icon.ChevronRight(icon.Props{Class: "size-4"})
								</button>
							</div>
							</div>
						</div>
						</form>

						<div class="w-1/5 shrink-0 px-1" data-wizard-step="3">
							<div class="account-wizard-panel">
							<div class="account-wizard-scroll" data-wizard-service-content="contacts">
								@ContactSyncSettings(data)
							</div>
						<div class="account-wizard-controls flex justify-between gap-2">
								<button type="button" onclick="editWizardGo(2)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
									@icon.ArrowLeft(icon.Props{Class: "size-4"})
									Back
								</button>
								<div class="flex flex-wrap justify-end gap-2">
									<button type="submit" form="edit-account-form" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg border border-border hover:bg-accent transition-colors">Skip</button>
									<button type="submit" form={ fmt.Sprintf("account-contact-sync-form-%s", data.AccountID) } data-contact-sync-save-button data-account-id={ data.AccountID } class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors disabled:pointer-events-none disabled:opacity-70">
										Save
									</button>
								</div>
							</div>
							</div>
						</div>

						<div class="w-1/5 shrink-0 px-1" data-wizard-step="4">
							<div class="account-wizard-panel">
							<div class="account-wizard-scroll">
								<div id="edit-step-4-content">
									@WizardConnectionTestStep(data.AccountID, "edit")
								</div>
							</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			@EditAccountWizardFooter(data)
		}
	}
}

templ EditAccountWizardFooter(data models.EditAccountData) {
	<div id="edit-wizard-footer" class="account-wizard-card-footer">
		<div data-wizard-footer-step="0" data-active="true" class="flex justify-end">
			<button type="button" onclick="editWizardGo(1)" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
				Next
				@icon.ChevronRight(icon.Props{Class: "size-4"})
			</button>
		</div>
		<div data-wizard-footer-step="1" data-active="false" class="hidden flex justify-between">
			<button type="button" onclick="editWizardGo(0)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
				@icon.ArrowLeft(icon.Props{Class: "size-4"})
				Back
			</button>
			<button type="button" onclick="editWizardGo(2)" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
				Next
				@icon.ChevronRight(icon.Props{Class: "size-4"})
			</button>
		</div>
		<div data-wizard-footer-step="2" data-active="false" class="hidden flex justify-between">
			<button type="button" onclick="editWizardGo(1)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
				@icon.ArrowLeft(icon.Props{Class: "size-4"})
				Back
			</button>
			<button type="button" onclick="editWizardGo(3)" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
				Next
				@icon.ChevronRight(icon.Props{Class: "size-4"})
			</button>
		</div>
		<div data-wizard-footer-step="3" data-active="false" class="hidden flex justify-between gap-2">
			<button type="button" onclick="editWizardGo(2)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
				@icon.ArrowLeft(icon.Props{Class: "size-4"})
				Back
			</button>
			<div class="flex flex-wrap justify-end gap-2">
				<button type="submit" form="edit-account-form" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg border border-border hover:bg-accent transition-colors">Skip</button>
				<button type="submit" form={ fmt.Sprintf("account-contact-sync-form-%s", data.AccountID) } data-contact-sync-save-button data-account-id={ data.AccountID } class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors disabled:pointer-events-none disabled:opacity-70">
					Save
				</button>
			</div>
		</div>
		<div id="edit-wizard-footer-step-4" data-wizard-footer-step="4" data-active="false" class="hidden flex justify-between gap-2">
			<button type="button" onclick="editWizardGo(3)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
				@icon.ArrowLeft(icon.Props{Class: "size-4"})
				Back
			</button>
			<a href="/settings/accounts" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">Done</a>
		</div>
	</div>
}

templ ContactSyncSettings(data models.EditAccountData) {
	{{ sameCardDAVAuth := strings.TrimSpace(data.ContactSync.Username) == "" || strings.TrimSpace(data.ContactSync.Username) == strings.TrimSpace(data.Username) }}
	<div class="space-y-3">
		<div class="account-wizard-sticky-header flex items-start justify-between gap-4">
			<div class="min-w-0">
				<h4 class="text-sm font-semibold text-foreground flex items-center gap-2">
					@icon.BookUser(icon.Props{Class: "size-4 text-muted-foreground"})
					Contact sync
				</h4>
				<p class="mt-1 text-xs text-muted-foreground leading-relaxed">Control whether this account appears as a contact sync target.</p>
			</div>
			if data.ContactSync.Enabled || data.Provider == "gmail" {
				<span class="shrink-0 rounded-full bg-emerald-500/10 px-2 py-0.5 text-[11px] font-semibold text-emerald-600 dark:text-emerald-400">Enabled</span>
			} else {
				<span class="shrink-0 rounded-md bg-muted px-2 py-0.5 text-[11px] font-semibold text-muted-foreground">Not configured</span>
			}
		</div>
		if data.Provider == "gmail" {
			<div class="rounded-lg border border-border bg-background/50 p-3 text-xs text-muted-foreground leading-relaxed">Gmail contacts use your Google authorization. This account is already available in contact sync targets.</div>
		} else {
			<form id={ fmt.Sprintf("account-contact-sync-form-%s", data.AccountID) } data-contact-sync-form data-account-id={ data.AccountID } hx-post={ fmt.Sprintf("/api/accounts/%s/contacts/sync", data.AccountID) } hx-target={ fmt.Sprintf("#account-contact-sync-status-%s", data.AccountID) } hx-swap="innerHTML" class="space-y-3">
				<div id={ fmt.Sprintf("account-contact-sync-fields-%s", data.AccountID) } class="grid gap-3 sm:grid-cols-2">
					<div class="sm:col-span-2">
						<div class="mb-1.5 flex items-center justify-between gap-2">
							<label class="text-xs font-medium text-muted-foreground">Base URL</label>
							<button type="button" data-carddav-discover data-carddav-autodiscover="true" data-account-id={ data.AccountID } data-fields-id={ fmt.Sprintf("account-contact-sync-fields-%s", data.AccountID) } data-status-id={ fmt.Sprintf("account-contact-sync-status-%s", data.AccountID) } class="inline-flex items-center rounded-md border border-border/80 px-2 py-0.5 text-[10px] font-semibold text-muted-foreground transition-colors hover:bg-accent hover:text-foreground">
								Attempt URL autodiscover
							</button>
						</div>
						@input.Input(input.Props{Name: "base_url", Type: input.TypeURL, Value: data.ContactSync.BaseURL, Placeholder: "https://dav.example.com/"})
					</div>
					<label class="sm:col-span-2 flex items-center gap-2 cursor-pointer">
						@checkbox.Checkbox(checkbox.Props{
							Name:       "use_account_credentials",
							Value:      "1",
							Checked:    sameCardDAVAuth,
							Attributes: templ.Attributes{"onchange": "toggleCardDAVAuth(this)"},
						})
						<span class="text-sm">Use same credentials as incoming mail</span>
					</label>
					<div class={ "sm:col-span-2 grid gap-3 sm:grid-cols-2", templ.KV("opacity-50", sameCardDAVAuth) } data-carddav-credential-fields>
						<div>
							<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Username</label>
							@input.Input(input.Props{Name: "username", Type: input.TypeText, Value: data.ContactSync.Username, Placeholder: data.Username, Disabled: sameCardDAVAuth})
						</div>
						<div>
							<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Password or app password</label>
							@input.Input(input.Props{Name: "password", Type: input.TypePassword, Placeholder: contactSyncPasswordPlaceholder(data.ContactSync), Disabled: sameCardDAVAuth})
						</div>
					</div>
					if len(data.ContactSync.AddressBooks) > 1 {
						<div class="sm:col-span-2 rounded-lg border border-border bg-background/45 p-3" data-carddav-addressbook-section>
							<div class="text-xs font-semibold text-foreground">Selected address books</div>
							<p class="mt-1 text-[11px] leading-relaxed text-muted-foreground">Select one or more address books to sync. The default is used for new contacts.</p>
							<div class="mt-3 space-y-2">
								for i, book := range data.ContactSync.AddressBooks {
									<label class="flex w-full items-start gap-3 rounded-md border border-primary bg-primary/10 px-3 py-2 text-xs">
										<span class="mt-0.5 inline-flex">
											@checkbox.Checkbox(checkbox.Props{Name: "addressbook_url", Value: book.URL, Checked: true})
										</span>
										<input type="hidden" name="addressbook_id" value={ book.ID }/>
										<input type="hidden" name="addressbook_name" value={ book.Name }/>
										<div class="min-w-0 flex-1">
											<div class="font-semibold text-foreground">{ contactAddressBookName(book) }</div>
											<div class="mt-0.5 truncate text-muted-foreground">{ book.URL }</div>
											<label class="mt-2 inline-flex items-center gap-1.5 text-[11px] text-muted-foreground">
												if book.Default || (!contactSyncHasDefaultBook(data.ContactSync.AddressBooks) && i == 0) {
													@radio.Radio(radio.Props{Name: "default_addressbook_url", Value: book.URL, Checked: true})
												} else {
													@radio.Radio(radio.Props{Name: "default_addressbook_url", Value: book.URL})
												}
												Default for new contacts
											</label>
										</div>
									</label>
								}
							</div>
						</div>
					} else if strings.TrimSpace(data.ContactSync.AddressBookURL) != "" {
						<div class="sm:col-span-2 rounded-md border border-border bg-background/35 px-3 py-2" data-carddav-addressbook-section data-carddav-manual-addressbook>
							<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Exact address book URL</label>
							@input.Input(input.Props{Name: "addressbook_url", Type: input.TypeURL, Value: data.ContactSync.AddressBookURL, Placeholder: "https://dav.example.com/addressbooks/user/default/"})
						</div>
					} else {
						<div class="hidden sm:col-span-2 rounded-md border border-border bg-background/35 px-3 py-2" data-carddav-addressbook-section data-carddav-manual-addressbook>
							<label class="text-xs font-medium text-muted-foreground mb-1.5 block">Exact address book URL</label>
							@input.Input(input.Props{Name: "addressbook_url", Type: input.TypeURL, Placeholder: "https://dav.example.com/addressbooks/user/default/"})
						</div>
					}
				</div>
				<div id={ fmt.Sprintf("account-contact-sync-status-%s", data.AccountID) } class="min-h-0"></div>
				<div class="flex flex-wrap justify-end gap-2">
					@CardDAVDiscoverAddressBooksButton(data.AccountID, fmt.Sprintf("account-contact-sync-fields-%s", data.AccountID), fmt.Sprintf("account-contact-sync-status-%s", data.AccountID), data.ContactSync.BaseURL)
					@CardDAVManualAddressBookButton(fmt.Sprintf("account-contact-sync-fields-%s", data.AccountID), data.ContactSync.BaseURL)
				</div>
			</form>
		}
	</div>
}

func contactSyncPasswordPlaceholder(cfg models.ContactSyncConfig) string {
	if cfg.HasPassword {
		return "Leave blank to keep current"
	}
	return "App password"
}

func contactAddressBookName(book models.ContactAddressBook) string {
	if strings.TrimSpace(book.Name) != "" {
		return strings.TrimSpace(book.Name)
	}
	return "Address book"
}

func contactSyncHasDefaultBook(books []models.ContactAddressBook) bool {
	for _, book := range books {
		if book.Default {
			return true
		}
	}
	return false
}

templ CardDAVBaseURLRequiredTooltip(hidden bool) {
	<span data-carddav-disabled-action class={ "inline-flex", templ.KV("!hidden", hidden) }>
		@tooltip.Tooltip() {
			@tooltip.Trigger(tooltip.TriggerProps{Class: "inline-flex"}) {
				<span class="inline-flex cursor-not-allowed" title="Fill the Base URL first, or use Attempt URL autodiscover.">
					{ children... }
				</span>
			}
			@tooltip.Content(tooltip.ContentProps{Position: tooltip.PositionTop, ShowArrow: true, Class: "max-w-56 px-3 py-1.5 text-center text-xs leading-relaxed"}) {
				Fill the Base URL first, or use Attempt URL autodiscover.
			}
		}
	</span>
}

templ CardDAVDiscoverAddressBooksButton(accountID string, fieldsID string, statusID string, baseURL string) {
	{{ disabled := strings.TrimSpace(baseURL) == "" }}
	<span data-carddav-base-url-action data-fields-id={ fieldsID } class="contents">
		<button type="button" data-carddav-enabled-action data-carddav-discover data-account-id={ accountID } data-fields-id={ fieldsID } data-status-id={ statusID } class={ "inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-2 text-xs font-semibold text-foreground hover:bg-accent", templ.KV("!hidden", disabled) }>
			@icon.Search(icon.Props{Class: "size-3.5"})
			Connect and discover address books
		</button>
		@CardDAVBaseURLRequiredTooltip(!disabled) {
			<button type="button" disabled class="pointer-events-none inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-2 text-xs font-semibold text-muted-foreground opacity-50">
				@icon.Search(icon.Props{Class: "size-3.5"})
				Connect and discover address books
			</button>
		}
	</span>
}

templ CardDAVManualAddressBookButton(fieldsID string, baseURL string) {
	{{ disabled := strings.TrimSpace(baseURL) == "" }}
	<span data-carddav-base-url-action data-fields-id={ fieldsID } class="contents">
		<button type="button" data-carddav-enabled-action data-carddav-manual data-fields-id={ fieldsID } class={ "inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-2 text-xs font-semibold text-foreground hover:bg-accent", templ.KV("!hidden", disabled) }>
			@icon.Pencil(icon.Props{Class: "size-3.5"})
			Enter address book URL manually
		</button>
		@CardDAVBaseURLRequiredTooltip(!disabled) {
			<button type="button" disabled class="pointer-events-none inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-2 text-xs font-semibold text-muted-foreground opacity-50">
				@icon.Pencil(icon.Props{Class: "size-3.5"})
				Enter address book URL manually
			</button>
		}
	</span>
}

templ AddAccountPostCreateStep(accountID string) {
	<div id="add-wizard-footer-step-3" data-wizard-footer-step="3" data-active="false" hx-swap-oob="outerHTML" class="hidden flex-wrap justify-between gap-2">
		<button type="button" onclick="wizardGo(2)" class="inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground">
			@icon.ArrowLeft(icon.Props{Class: "size-4"})
			Back
		</button>
		<div class="flex flex-wrap justify-end gap-2">
			<a href="/settings/accounts" class="inline-flex items-center gap-1.5 rounded-lg border border-border px-4 py-2 text-sm font-medium transition-colors hover:bg-accent">Done</a>
			<button type="submit" form={ fmt.Sprintf("add-contact-sync-form-%s", accountID) } class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
				Save
			</button>
		</div>
	</div>
	<div class="flex h-full flex-col pt-1">
		<div class="account-wizard-scroll space-y-5">
		<h4 class="account-wizard-sticky-header text-sm font-semibold text-foreground flex items-center gap-2">
			@icon.BookUser(icon.Props{Class: "size-4 text-muted-foreground"})
			Contact sync
		</h4>
		<div class="flex items-center gap-3 rounded-lg border border-emerald-500/20 bg-emerald-500/10 p-3">
			@icon.Check(icon.Props{Class: "size-5 text-emerald-500"})
			<div class="min-w-0">
				<p class="text-sm font-semibold text-emerald-600 dark:text-emerald-400">Account created</p>
				<p class="text-xs text-muted-foreground">Mail sync has started. Contact sync is optional.</p>
			</div>
		</div>
		<div
			id="wizard-test-results"
			hx-post={ fmt.Sprintf("/api/accounts/%s/test?wizard=add", accountID) }
			hx-trigger="load"
			hx-target="#wizard-test-results"
			hx-swap="innerHTML"
			class="space-y-3"
		>
			<div class="flex items-center justify-center gap-2 py-4">
				<div class="size-4 animate-spin rounded-full border-2 border-muted-foreground/30 border-t-muted-foreground"></div>
				<span class="text-xs text-muted-foreground">Testing mail connection...</span>
			</div>
		</div>
		<form id={ fmt.Sprintf("add-contact-sync-form-%s", accountID) } hx-post={ fmt.Sprintf("/api/accounts/%s/contacts/sync", accountID) } hx-target={ fmt.Sprintf("#add-contact-sync-status-%s", accountID) } hx-swap="innerHTML" class="rounded-lg border border-border bg-background/45 p-4">
			<div class="mb-3 flex items-start justify-between gap-4">
				<div class="min-w-0">
					<h4 class="flex items-center gap-2 text-sm font-semibold text-foreground">
						@icon.BookUser(icon.Props{Class: "size-4 text-muted-foreground"})
						Contact sync
					</h4>
					<p class="mt-1 text-xs leading-relaxed text-muted-foreground">Enable this only if the account has a CardDAV address book.</p>
				</div>
				<span class="shrink-0 rounded-full bg-muted px-2 py-0.5 text-[11px] font-semibold text-muted-foreground">Optional</span>
			</div>
			<div id={ fmt.Sprintf("add-contact-sync-fields-%s", accountID) } class="space-y-3">
				<div class="grid gap-3 sm:grid-cols-2">
					<div class="sm:col-span-2">
						<div class="mb-1.5 flex items-center justify-between gap-2">
							<label class="text-xs font-medium text-muted-foreground">Base URL</label>
							<button type="button" data-carddav-discover data-carddav-autodiscover="true" data-account-id={ accountID } data-fields-id={ fmt.Sprintf("add-contact-sync-fields-%s", accountID) } data-status-id={ fmt.Sprintf("add-contact-sync-status-%s", accountID) } class="inline-flex items-center rounded-md border border-border/80 px-2 py-0.5 text-[10px] font-semibold text-muted-foreground transition-colors hover:bg-accent hover:text-foreground">
								Attempt URL autodiscover
							</button>
						</div>
						@input.Input(input.Props{Name: "base_url", Type: input.TypeURL, Placeholder: "https://dav.example.com/"})
					</div>
					<label class="flex items-center gap-2 cursor-pointer sm:col-span-2">
						@checkbox.Checkbox(checkbox.Props{
							Name:       "use_account_credentials",
							Value:      "1",
							Checked:    true,
							Attributes: templ.Attributes{"onchange": "toggleCardDAVAuth(this)"},
						})
						<span class="text-sm">Use same credentials as incoming mail</span>
					</label>
					<div class="sm:col-span-2 grid gap-3 sm:grid-cols-2 opacity-50" data-carddav-credential-fields>
						<div>
							<label class="mb-1.5 block text-xs font-medium text-muted-foreground">Username</label>
							@input.Input(input.Props{Name: "username", Type: input.TypeText, Placeholder: "Same as incoming mail", Disabled: true})
						</div>
						<div>
							<label class="mb-1.5 block text-xs font-medium text-muted-foreground">Password or app password</label>
							@input.Input(input.Props{Name: "password", Type: input.TypePassword, Placeholder: "Same as incoming mail", Disabled: true})
						</div>
					</div>
					<div class="hidden sm:col-span-2 rounded-md border border-border bg-background/35 px-3 py-2" data-carddav-addressbook-section data-carddav-manual-addressbook>
						<label class="mb-1.5 block text-xs font-medium text-muted-foreground">Exact address book URL</label>
						@input.Input(input.Props{Name: "addressbook_url", Type: input.TypeURL, Placeholder: "https://dav.example.com/addressbooks/user/default/"})
					</div>
				</div>
			</div>
			<div id={ fmt.Sprintf("add-contact-sync-status-%s", accountID) } class="mt-3 min-h-0"></div>
			<div class="mt-4 flex flex-wrap justify-end gap-2">
				@CardDAVDiscoverAddressBooksButton(accountID, fmt.Sprintf("add-contact-sync-fields-%s", accountID), fmt.Sprintf("add-contact-sync-status-%s", accountID), "")
				@CardDAVManualAddressBookButton(fmt.Sprintf("add-contact-sync-fields-%s", accountID), "")
			</div>
		</form>
		</div>
		<div class="account-wizard-controls flex flex-wrap justify-between gap-2">
			<button type="button" onclick="wizardGo(2)" class="inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground">
				@icon.ArrowLeft(icon.Props{Class: "size-4"})
				Back
			</button>
			<div class="flex flex-wrap justify-end gap-2">
				<a href="/settings/accounts" class="inline-flex items-center gap-1.5 rounded-lg border border-border px-4 py-2 text-sm font-medium transition-colors hover:bg-accent">Done</a>
				<button type="submit" form={ fmt.Sprintf("add-contact-sync-form-%s", accountID) } class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
					Save
				</button>
			</div>
		</div>
	</div>
}

templ WizardStepSuccess(heading string, accountID string, wizardType string) {
	<div class="space-y-4 pt-2">
		<h4 class="account-wizard-sticky-header text-sm font-semibold text-foreground flex items-center gap-2">
			@icon.Check(icon.Props{Class: "size-4 text-muted-foreground"})
			Finish
		</h4>
		<div class="flex items-center gap-3 p-3 rounded-lg bg-muted/35 border border-border">
			@icon.Check(icon.Props{Class: "size-5 text-muted-foreground"})
			<p class="text-sm font-medium text-foreground">{ heading }</p>
		</div>
		<div
			id="wizard-test-results"
			hx-post={ fmt.Sprintf("/api/accounts/%s/test?wizard=%s", accountID, wizardType) }
			hx-trigger="load"
			hx-target="#wizard-test-results"
			hx-swap="innerHTML"
			class="space-y-3"
		>
			<div class="flex items-center justify-center py-4 gap-2">
				<div class="size-4 border-2 border-muted-foreground/30 border-t-muted-foreground rounded-full animate-spin"></div>
				<span class="text-xs text-muted-foreground">Testing connection...</span>
			</div>
		</div>
	</div>
}

templ WizardConnectionTestStep(accountID string, wizardType string) {
	<div class="space-y-4 pt-2">
		<h4 class="account-wizard-sticky-header text-sm font-semibold text-foreground flex items-center gap-2">
			@icon.Check(icon.Props{Class: "size-4 text-muted-foreground"})
			Finish
		</h4>
		<div
			id="wizard-test-results"
			hx-post={ fmt.Sprintf("/api/accounts/%s/test?wizard=%s", accountID, wizardType) }
			hx-trigger="load"
			hx-target="#wizard-test-results"
			hx-swap="innerHTML"
			class="space-y-3"
		>
			<div class="flex items-center justify-center py-4 gap-2">
				<div class="size-4 border-2 border-muted-foreground/30 border-t-muted-foreground rounded-full animate-spin"></div>
				<span class="text-xs text-muted-foreground">Testing connection...</span>
			</div>
		</div>
	</div>
}

templ AccountFormError(message string) {
	<div class="space-y-4">
		<div class="flex items-center gap-3 p-3 rounded-lg bg-destructive/10 border border-destructive/20">
			@icon.CircleAlert(icon.Props{Class: "size-5 text-destructive"})
			<p class="text-sm text-destructive">{ message }</p>
		</div>
		<div class="flex justify-end pt-2">
		<a href="/settings/accounts" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-1.5 rounded-md border border-border hover:bg-accent">
			@icon.ArrowLeft(icon.Props{Class: "size-4"})
			Try Again
		</a>
		</div>
	</div>
}

templ ConnectionTestResults(results []models.ConnectionTestResult, accountID string, wizardType string) {
	{{ hasFailure := false }}
	<div class="space-y-3">
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
			for _, r := range results {
				if !r.Success {
					{{ hasFailure = true }}
				}
				<div class={
					"flex items-center gap-3 p-3 rounded-lg border",
					templ.KV("bg-muted/35 border-border", r.Success),
					templ.KV("bg-destructive/10 border-destructive/20", !r.Success),
				}>
					if r.Success {
						@icon.Check(icon.Props{Class: "size-5 text-muted-foreground"})
					} else {
						@icon.X(icon.Props{Class: "size-5 text-destructive"})
					}
					<div class="flex-1 min-w-0">
						<div class="flex items-center gap-2">
							<span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">{ r.Service }</span>
							if r.Success {
								<span class="text-xs text-muted-foreground font-medium">{ r.Message }</span>
							}
						</div>
						if !r.Success {
							<p class="text-xs text-destructive mt-0.5">{ r.Error }</p>
							<p class="text-xs text-muted-foreground mt-0.5">{ r.Message }</p>
						}
					</div>
				</div>
			}
		</div>
		if wizardType == "edit" {
			<div id="edit-wizard-footer-step-4" data-wizard-footer-step="4" data-active="false" hx-swap-oob="outerHTML" class="hidden justify-between gap-2">
				<button type="button" onclick="editWizardGo(3)" class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors px-3 py-2 rounded-md border border-border hover:bg-accent">
					@icon.ArrowLeft(icon.Props{Class: "size-4"})
					Back
				</button>
				<div class="flex gap-2">
					if hasFailure {
						<a href="/settings/accounts" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg border border-border hover:bg-accent transition-colors">Save Anyway</a>
					}
					<a href="/settings/accounts" class="inline-flex items-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">Done</a>
				</div>
			</div>
		}
		if wizardType == "" {
			<button
				class="w-full inline-flex items-center justify-center gap-1.5 text-sm font-medium px-4 py-2 rounded-lg border border-border hover:bg-accent transition-colors"
				hx-post={ fmt.Sprintf("/api/accounts/%s/test", accountID) }
				hx-target="#test-results"
				hx-swap="outerHTML"
			>
				@icon.RefreshCw(icon.Props{Class: "size-4"})
				Retry
			</button>
		}
	</div>
}
